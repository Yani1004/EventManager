@page "/admin/users"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using EventManager.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager

<PageTitle>All Users</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">All Users</h1>
            <p class="text-muted mb-0">View all registered users and their current roles.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a href="/admin" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @messageCss alert-dismissible fade show" role="alert">
            @Message
            <button type="button" class="btn-close" @onclick="ClearMessage"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>Loading users...</span>
                </div>
            </div>
        </div>
    }
    else if (users.Count == 0)
    {
        <div class="alert alert-info">No users found.</div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:60px;">#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Requested Role</th>
                                <th>Approved</th>
                                <th>Current Role</th>
                                <th class="text-center" style="width:180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < users.Count; i++)
                            {
                                var user = users[i];

                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@(string.IsNullOrWhiteSpace(user.RequestedRole) ? "-" : user.RequestedRole)</td>
                                    <td>
                                        @if (user.IsApproved)
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetRoleBadgeClass(user.CurrentRole)">
                                            @user.CurrentRole
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (user.RequestedRole == "EventManager" && !user.IsApproved)
                                        {
                                            <div class="d-flex justify-content-center gap-2">
                                                <button class="btn btn-success btn-sm"
                                                        title="Approve"
                                                        disabled="@isProcessing"
                                                        @onclick="() => ApproveUser(user.Id)">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>

                                                <button class="btn btn-danger btn-sm"
                                                        title="Reject"
                                                        disabled="@isProcessing"
                                                        @onclick="() => RejectUser(user.Id)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No actions</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<UserListItemViewModel> users = new();
    private bool isLoading = true;
    private bool isProcessing;
    private string? Message;
    private string messageCss = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        users.Clear();

        var allUsers = await UserManager.Users
            .OrderBy(u => u.FirstName)
            .ThenBy(u => u.LastName)
            .ToListAsync();

        foreach (var user in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);

            users.Add(new UserListItemViewModel
            {
                Id = user.Id,
                FullName = $"{user.FirstName} {user.LastName}".Trim(),
                Email = user.Email ?? string.Empty,
                RequestedRole = user.RequestedRole,
                IsApproved = user.IsApproved,
                CurrentRole = roles.FirstOrDefault() ?? "No Role"
            });
        }

        isLoading = false;
    }

    private async Task ApproveUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var user = await UserManager.FindByIdAsync(userId);
        if (user == null)
        {
            ShowError("User not found.");
            isProcessing = false;
            return;
        }

        user.IsApproved = true;
        user.RequestedRole = "EventManager";

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            ShowError(string.Join(" ", updateResult.Errors.Select(e => e.Description)));
            isProcessing = false;
            return;
        }

        if (!await UserManager.IsInRoleAsync(user, "EventManager"))
        {
            var addRoleResult = await UserManager.AddToRoleAsync(user, "EventManager");
            if (!addRoleResult.Succeeded)
            {
                ShowError(string.Join(" ", addRoleResult.Errors.Select(e => e.Description)));
                isProcessing = false;
                return;
            }
        }

        if (await UserManager.IsInRoleAsync(user, "Attendee"))
        {
            await UserManager.RemoveFromRoleAsync(user, "Attendee");
        }

        ShowSuccess($"User {user.Email} was approved successfully.");
        await LoadUsers();
        isProcessing = false;
    }

    private async Task RejectUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var user = await UserManager.FindByIdAsync(userId);
        if (user == null)
        {
            ShowError("User not found.");
            isProcessing = false;
            return;
        }

        user.RequestedRole = "Attendee";
        user.IsApproved = true;

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            ShowError(string.Join(" ", updateResult.Errors.Select(e => e.Description)));
            isProcessing = false;
            return;
        }

        if (!await UserManager.IsInRoleAsync(user, "Attendee"))
        {
            var addRoleResult = await UserManager.AddToRoleAsync(user, "Attendee");
            if (!addRoleResult.Succeeded)
            {
                ShowError(string.Join(" ", addRoleResult.Errors.Select(e => e.Description)));
                isProcessing = false;
                return;
            }
        }

        if (await UserManager.IsInRoleAsync(user, "EventManager"))
        {
            await UserManager.RemoveFromRoleAsync(user, "EventManager");
        }

        ShowSuccess($"User {user.Email} remains an Attendee.");
        await LoadUsers();
        isProcessing = false;
    }

    private string GetRoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-dark",
        "EventManager" => "bg-primary",
        "Attendee" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private void ShowSuccess(string message)
    {
        Message = message;
        messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        Message = message;
        messageCss = "alert-danger";
    }

    private void ClearMessage()
    {
        Message = null;
    }

    public class UserListItemViewModel
    {
        public string Id { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? RequestedRole { get; set; }
        public bool IsApproved { get; set; }
        public string CurrentRole { get; set; } = "No Role";
    }
}