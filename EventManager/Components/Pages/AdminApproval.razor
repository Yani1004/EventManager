@page "/admin/approvals"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using EventManager.Models
@using EventManager.Services.Interfaces
@using Radzen
@using Radzen.Blazor

@inject IAdminService AdminService
@inject NavigationManager NavigationManager

<PageTitle>Approve Event Managers</PageTitle>

<div class="approvals-page">
    <RadzenStack Gap="1.5rem" class="approvals-shell">

        <RadzenCard class="approvals-hero">
            <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                            <div class="hero-icon-wrap">
                                <RadzenIcon Icon="how_to_reg" class="hero-icon" />
                            </div>

                            <div>
                                <div class="hero-title">Pending Event Manager Requests</div>
                                <div class="hero-subtitle">
                                    Review, approve, or reject users who want to become event managers.
                                </div>
                            </div>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 JustifyContent="JustifyContent.End"
                                 AlignItems="AlignItems.Center"
                                 Gap="0.75rem"
                                 class="hero-actions">
                        <RadzenButton Text="Back to Dashboard"
                                      Icon="arrow_back"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Variant="Variant.Outlined"
                                      Size="ButtonSize.Large"
                                      class="dashboard-back-btn"
                                      Click='@(() => NavigationManager.NavigateTo("/admin"))' />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <RadzenAlert AlertStyle="@(messageCss == "success" ? AlertStyle.Success : AlertStyle.Danger)"
                         Variant="Variant.Flat"
                         Shade="Shade.Light"
                         AllowClose="true"
                         Close="@ClearMessage">
                @Message
            </RadzenAlert>
        }

        @if (isLoading)
        {
            <RadzenCard class="state-card">
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.Center"
                             Gap="1rem"
                             class="state-stack">
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                    <RadzenStack Gap="0.35rem">
                        <div class="state-title">Loading requests</div>
                        <div class="state-subtitle">Please wait while pending approvals are loaded.</div>
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        }
        else if (pendingUsers.Count == 0)
        {
            <RadzenCard class="empty-card">
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem" class="empty-stack">
                    <div class="empty-icon-wrap">
                        <RadzenIcon Icon="task_alt" class="empty-icon" />
                    </div>

                    <RadzenStack AlignItems="AlignItems.Center" Gap="0.35rem">
                        <div class="empty-title">No pending requests</div>
                        <div class="empty-subtitle">There are currently no users waiting for Event Manager approval.</div>
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        }
        else
        {
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeLG="4">
                    <RadzenCard class="stat-card">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                            <div class="stat-icon stat-icon-primary">
                                <RadzenIcon Icon="pending_actions" />
                            </div>

                            <RadzenStack Gap="0.25rem">
                                <div class="stat-value">@pendingUsers.Count</div>
                                <div class="stat-label">Pending approvals</div>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeLG="4">
                    <RadzenCard class="stat-card">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                            <div class="stat-icon stat-icon-success">
                                <RadzenIcon Icon="verified_user" />
                            </div>

                            <RadzenStack Gap="0.25rem">
                                <div class="stat-value">@pendingUsers.Count(u => u.RequestedRole == "EventManager")</div>
                                <div class="stat-label">Manager requests</div>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeLG="4">
                    <RadzenCard class="stat-card">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                            <div class="stat-icon stat-icon-warning">
                                <RadzenIcon Icon="admin_panel_settings" />
                            </div>

                            <RadzenStack Gap="0.25rem">
                                <div class="stat-value">Admin</div>
                                <div class="stat-label">Approval access active</div>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>

            <RadzenCard class="grid-card">
                <RadzenDataGrid Data="@pendingUsers"
                                TItem="PendingEventManagerListItem"
                                AllowPaging="true"
                                PageSize="8"
                                AllowSorting="true"
                                AllowFiltering="false"
                                Responsive="true"
                                GridLines="DataGridGridLines.None"
                                RowHover="true"
                                class="approvals-grid">

                    <HeaderTemplate>
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     AlignItems="AlignItems.Center"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     Gap="1rem"
                                     class="grid-header">
                            <RadzenStack Gap="0.2rem">
                                <div class="grid-title">Approval Queue</div>
                                <div class="grid-subtitle">Manage pending users and update their access.</div>
                            </RadzenStack>

                            <RadzenBadge Text="@($"{pendingUsers.Count} Pending")"
                                         BadgeStyle="BadgeStyle.Warning"
                                         Shade="Shade.Light" />
                        </RadzenStack>
                    </HeaderTemplate>

                    <Columns>
                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Title="#" Width="70px" Sortable="false" Filterable="false">
                            <Template Context="user">
                                @(pendingUsers.IndexOf(user) + 1)
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Property="FirstName" Title="First Name" />
                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Property="LastName" Title="Last Name" />
                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Property="Email" Title="Email" />
                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Property="RequestedRole" Title="Requested Role" />

                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Title="Status" Width="140px" Sortable="false" Filterable="false">
                            <Template Context="user">
                                <RadzenBadge Text="Pending"
                                             BadgeStyle="BadgeStyle.Warning"
                                             Shade="Shade.Light" />
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="PendingEventManagerListItem" Title="Actions" Width="190px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                            <Template Context="user">
                                <RadzenStack Orientation="Orientation.Horizontal"
                                             AlignItems="AlignItems.Center"
                                             JustifyContent="JustifyContent.Center"
                                             Gap="0.5rem">
                                    <RadzenButton Icon="check_circle"
                                                  ButtonStyle="ButtonStyle.Success"
                                                  Variant="Variant.Flat"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => ApproveUser(user.Id))' />

                                    <RadzenButton Icon="cancel"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Variant="Variant.Flat"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => RejectUser(user.Id))' />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }
    </RadzenStack>
</div>

<style>
    .approvals-page {
        padding: 1.5rem;
        background: linear-gradient(180deg, #f6f8fc 0%, #eef3f9 100%);
        min-height: calc(100vh - 2rem);
    }

    .approvals-shell {
        max-width: 1400px;
        margin: 0 auto;
    }

    .approvals-hero,
    .grid-card,
    .stat-card,
    .state-card,
    .empty-card {
        border-radius: 28px;
        border: 1px solid #e7edf5;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .dashboard-back-btn {
        min-height: 48px;
        padding: 0 1.15rem;
        border-radius: 14px !important;
        font-weight: 600;
    }

    .approvals-hero {
        padding: 0.5rem;
    }

    .hero-icon-wrap {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #5b6df9 0%, #7c66ff 100%);
        box-shadow: 0 12px 24px rgba(91, 109, 249, 0.25);
        flex-shrink: 0;
    }

    .hero-icon {
        color: white;
        font-size: 28px;
    }

    .hero-title {
        font-size: 1.55rem;
        font-weight: 800;
        color: #15263a;
        line-height: 1.2;
    }

    .hero-subtitle {
        font-size: 0.98rem;
        color: #6b7a90;
        line-height: 1.5;
    }

    .hero-actions {
        height: 100%;
    }

    .stat-card {
        padding: 0.35rem;
    }

    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .stat-icon-primary {
        background: #eef2ff;
        color: #4f46e5;
    }

    .stat-icon-success {
        background: #ecfdf3;
        color: #16a34a;
    }

    .stat-icon-warning {
        background: #fff7ed;
        color: #ea580c;
    }

    .stat-value {
        font-size: 1.35rem;
        font-weight: 800;
        color: #142236;
        line-height: 1.1;
    }

    .stat-label {
        font-size: 0.92rem;
        color: #708197;
    }

    .grid-card {
        overflow: hidden;
    }

    .grid-header {
        padding: 0.4rem 0.2rem 1rem 0.2rem;
    }

    .grid-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #142236;
    }

    .grid-subtitle {
        font-size: 0.9rem;
        color: #708197;
    }

    .state-card,
    .empty-card {
        padding: 2rem;
    }

    .state-stack,
    .empty-stack {
        min-height: 220px;
    }

    .state-title,
    .empty-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: #162336;
    }

    .state-subtitle,
    .empty-subtitle {
        font-size: 0.95rem;
        color: #708197;
    }

    .empty-icon-wrap {
        width: 74px;
        height: 74px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #ecfdf3 0%, #dff7e8 100%);
    }

    .empty-icon {
        font-size: 34px;
        color: #16a34a;
    }

    .approvals-grid .rz-datatable-tablewrapper table {
        border-collapse: separate;
        border-spacing: 0;
    }

    .approvals-grid .rz-column-title {
        font-weight: 700;
    }

    .approvals-grid .rz-cell-data,
    .approvals-grid .rz-sortable-column {
        color: #1f2f43;
    }

    .approvals-grid .rz-datatable-data tr td {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .approvals-grid .rz-datatable-data tr:hover {
        background: #f8fbff;
    }

   
</style>

@code {
    private List<PendingEventManagerListItem> pendingUsers = new();

    private string? Message;
    private string messageCss = "success";

    private bool isLoading = true;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingUsers();
    }

    private async Task LoadPendingUsers()
    {
        isLoading = true;
        pendingUsers = await AdminService.GetPendingEventManagerRequestsAsync();
        isLoading = false;
    }

    private async Task ApproveUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var result = await AdminService.ApproveEventManagerAsync(userId);

        if (result.Success)
        {
            ShowSuccess(result.Message);
            await LoadPendingUsers();
        }
        else
        {
            ShowError(result.Message);
        }

        isProcessing = false;
    }

    private async Task RejectUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var result = await AdminService.RejectEventManagerAsync(userId);

        if (result.Success)
        {
            ShowSuccess(result.Message);
            await LoadPendingUsers();
        }
        else
        {
            ShowError(result.Message);
        }

        isProcessing = false;
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        messageCss = "success";
    }

    private void ShowError(string message)
    {
        Message = message;
        messageCss = "error";
    }

    private void ClearMessage()
    {
        Message = null;
    }
}