@page "/admin/approvals"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using EventManager.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager

<PageTitle>Approve Event Managers</PageTitle>

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Pending Event Manager Requests</h1>
            <p class="text-muted mb-0">Approve or reject users who want to become event managers.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a href="/admin" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @messageCss alert-dismissible fade show">
            @Message
            <button class="btn-close" @onclick="ClearMessage"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="spinner-border text-primary"></div>
                    <span>Loading pending requests...</span>
                </div>
            </div>
        </div>
    }
    else if (pendingUsers.Count == 0)
    {
        <div class="alert alert-info shadow-sm">
            There are no pending Event Manager requests.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-dark">
                            <tr>
                                <th style="width:60px;">#</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Email</th>
                                <th>Requested Role</th>
                                <th>Status</th>
                                <th class="text-center" style="width:160px;">Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            @for (int i = 0; i < pendingUsers.Count; i++)
                            {
                                var user = pendingUsers[i];

                                <tr>

                                    <td>@(i + 1)</td>

                                    <td>@user.FirstName</td>

                                    <td>@user.LastName</td>

                                    <td>@user.Email</td>

                                    <td>@user.RequestedRole</td>

                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            Pending
                                        </span>
                                    </td>

                                    <td class="text-center">

                                        <div class="d-flex justify-content-center gap-2">

                                            <button class="btn btn-success btn-sm"
                                                    disabled="@isProcessing"
                                                    title="Approve"
                                                    @onclick="() => ApproveUser(user.Id)">
                                                <i class="bi bi-check-lg"></i>
                                            </button>

                                            <button class="btn btn-danger btn-sm"
                                                    disabled="@isProcessing"
                                                    title="Reject"
                                                    @onclick="() => RejectUser(user.Id)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    }

</div>

@code {

    private List<PendingEventManagerViewModel> pendingUsers = new();

    private string? Message;
    private string messageCss = "alert-success";

    private bool isLoading = true;
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingUsers();
    }

    private async Task LoadPendingUsers()
    {
        isLoading = true;

        pendingUsers.Clear();

        var users = await UserManager.Users
            .Where(u => u.RequestedRole == "EventManager" && !u.IsApproved)
            .OrderBy(u => u.FirstName)
            .ThenBy(u => u.LastName)
            .ToListAsync();

        foreach (var user in users)
        {
            pendingUsers.Add(new PendingEventManagerViewModel
            {
                Id = user.Id,
                Email = user.Email ?? "",
                FirstName = user.FirstName,
                LastName = user.LastName,
                RequestedRole = user.RequestedRole,
                IsApproved = user.IsApproved
            });
        }

        isLoading = false;
    }

    private async Task ApproveUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var user = await UserManager.FindByIdAsync(userId);

        if (user == null)
        {
            ShowError("User not found.");
            isProcessing = false;
            return;
        }

        user.IsApproved = true;
        user.RequestedRole = "EventManager";

        var updateResult = await UserManager.UpdateAsync(user);

        if (!updateResult.Succeeded)
        {
            ShowError(string.Join(" ", updateResult.Errors.Select(e => e.Description)));
            isProcessing = false;
            return;
        }

        if (!await UserManager.IsInRoleAsync(user, "EventManager"))
            await UserManager.AddToRoleAsync(user, "EventManager");

        if (await UserManager.IsInRoleAsync(user, "Attendee"))
            await UserManager.RemoveFromRoleAsync(user, "Attendee");

        ShowSuccess($"User {user.Email} approved as Event Manager.");

        await LoadPendingUsers();

        isProcessing = false;
    }

    private async Task RejectUser(string userId)
    {
        isProcessing = true;
        ClearMessage();

        var user = await UserManager.FindByIdAsync(userId);

        if (user == null)
        {
            ShowError("User not found.");
            isProcessing = false;
            return;
        }

        user.RequestedRole = "Rejected";
        user.IsApproved = false;

        var updateResult = await UserManager.UpdateAsync(user);

        if (!updateResult.Succeeded)
        {
            ShowError(string.Join(" ", updateResult.Errors.Select(e => e.Description)));
            isProcessing = false;
            return;
        }

        if (!await UserManager.IsInRoleAsync(user, "Attendee"))
            await UserManager.AddToRoleAsync(user, "Attendee");

        if (await UserManager.IsInRoleAsync(user, "EventManager"))
            await UserManager.RemoveFromRoleAsync(user, "EventManager");

        ShowSuccess($"User {user.Email} request rejected.");

        await LoadPendingUsers();

        isProcessing = false;
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        Message = message;
        messageCss = "alert-danger";
    }
    //code
    private void ClearMessage()
    {
        Message = null;
    }

}