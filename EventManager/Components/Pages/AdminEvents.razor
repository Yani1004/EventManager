@page "/admin/events"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using EventManager.Models
@using EventManager.Services.Interfaces
@using Radzen
@using Radzen.Blazor

@inject IAdminService AdminService
@inject NavigationManager NavigationManager

<PageTitle>Manage Events</PageTitle>

<RadzenStack Gap="1.25rem" class="admin-events-page">

    <RadzenCard class="events-hero-card">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
            <RadzenColumn Size="12" SizeLG="8">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                    <div class="hero-icon-wrap">
                        <RadzenIcon Icon="event_note" class="hero-main-icon" />
                    </div>

                    <RadzenStack Gap="0.35rem">
                        <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="hero-title">
                            Event Control Center
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="hero-subtitle">
                            Review platform events, flag suspicious content, hide listings, and restore visibility.
                        </RadzenText>
                    </RadzenStack>
                </RadzenStack>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeLG="4">
                <RadzenStack Orientation="Orientation.Horizontal"
                             JustifyContent="JustifyContent.End"
                             AlignItems="AlignItems.Center"
                             Gap="0.75rem"
                             class="hero-buttons">
                    <RadzenButton Text="Back to Dashboard"
                                  Icon="arrow_back"
                                  Size="ButtonSize.Large"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Outlined"
                                  Click='@(() => NavigationManager.NavigateTo("/admin"))'
                                  class="back-button" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <RadzenAlert AlertStyle="@(messageCss == "alert-success" ? AlertStyle.Success : AlertStyle.Danger)"
                     Variant="Variant.Flat"
                     Shade="Shade.Lighter"
                     AllowClose="true"
                     Close="@(_ => ClearMessage())"
                     class="events-alert">
            @Message
        </RadzenAlert>
    }

    @if (isLoading)
    {
        <RadzenCard class="state-card">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate"
                                           Size="ProgressBarCircularSize.Medium" />
                <RadzenStack Gap="0.2rem">
                    <RadzenText TextStyle="TextStyle.Body1" class="state-title">Loading events...</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="state-subtitle">Preparing event moderation data.</RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    }
    else if (events.Count == 0)
    {
        <RadzenCard class="state-card empty-card">
            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.75rem" class="empty-stack">
                <div class="empty-icon-wrap">
                    <RadzenIcon Icon="event_busy" class="empty-icon" />
                </div>
                <RadzenText TextStyle="TextStyle.H5" class="empty-title">No events found</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" class="empty-text">
                    When new events are created, they will appear here for admin review.
                </RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenCard class="metric-card metric-card-primary">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                        <RadzenStack Gap="0.3rem">
                            <RadzenText TextStyle="TextStyle.Body2" class="metric-label">Visible Results</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4" class="metric-value">@FilteredEvents.Count</RadzenText>
                        </RadzenStack>
                        <div class="metric-icon-wrap">
                            <RadzenIcon Icon="dashboard" class="metric-icon" />
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenCard class="metric-card metric-card-success">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                        <RadzenStack Gap="0.3rem">
                            <RadzenText TextStyle="TextStyle.Body2" class="metric-label">Active</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4" class="metric-value">@FilteredEvents.Count(e => e.Status == "Active")</RadzenText>
                        </RadzenStack>
                        <div class="metric-icon-wrap">
                            <RadzenIcon Icon="check_circle" class="metric-icon" />
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenCard class="metric-card metric-card-warning">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                        <RadzenStack Gap="0.3rem">
                            <RadzenText TextStyle="TextStyle.Body2" class="metric-label">Flagged</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4" class="metric-value">@FilteredEvents.Count(e => e.Status == "Flagged")</RadzenText>
                        </RadzenStack>
                        <div class="metric-icon-wrap">
                            <RadzenIcon Icon="flag" class="metric-icon" />
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenCard class="metric-card metric-card-dark">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                        <RadzenStack Gap="0.3rem">
                            <RadzenText TextStyle="TextStyle.Body2" class="metric-label">Hidden</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4" class="metric-value">@FilteredEvents.Count(e => e.Status == "Hidden")</RadzenText>
                        </RadzenStack>
                        <div class="metric-icon-wrap">
                            <RadzenIcon Icon="visibility_off" class="metric-icon" />
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard class="filters-panel">
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeLG="4">
                    <RadzenStack Gap="0.35rem">
                        <RadzenText TextStyle="TextStyle.Body2" class="input-label">Search</RadzenText>
                        <RadzenTextBox @bind-Value="searchTerm"
                                       Placeholder="Title, location, category..."
                                       Style="width: 100%;"
                                       class="filter-input" />
                    </RadzenStack>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeLG="3">
                    <RadzenStack Gap="0.35rem">
                        <RadzenText TextStyle="TextStyle.Body2" class="input-label">Status</RadzenText>
                        <RadzenDropDown @bind-Value="selectedStatus"
                                        Data="@statusOptions"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        Placeholder="All statuses"
                                        Style="width: 100%;"
                                        class="filter-input" />
                    </RadzenStack>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeLG="3">
                    <RadzenStack Gap="0.35rem">
                        <RadzenText TextStyle="TextStyle.Body2" class="input-label">Sort</RadzenText>
                        <RadzenDropDown @bind-Value="selectedSort"
                                        Data="@sortOptions"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        Style="width: 100%;"
                                        class="filter-input" />
                    </RadzenStack>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeLG="2">
                    <RadzenStack Gap="0.35rem">
                        <RadzenText TextStyle="TextStyle.Body2" class="input-label invisible-label">Clear</RadzenText>
                        <RadzenButton Text="Clear"
                                      Icon="filter_alt_off"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Variant="Variant.Outlined"
                                      Style="width: 100%;"
                                      Click="@ClearFilters"
                                      class="clear-button" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        <RadzenCard class="grid-shell">
            <RadzenDataGrid Data="@FilteredEvents"
                            TItem="AdminEventListItem"
                            AllowPaging="true"
                            PageSize="8"
                            PagerHorizontalAlign="HorizontalAlign.Right"
                            ShowPagingSummary="true"
                            class="admin-events-grid">

                <Columns>
                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Event">
                        <Template Context="ev">
                            <RadzenStack Gap="0.35rem">
                                <RadzenText TextStyle="TextStyle.Body1" class="event-name">
                                    @ev.Title
                                </RadzenText>

                                <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.75rem">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.35rem">
                                        <RadzenIcon Icon="schedule" class="tiny-icon" />
                                        <RadzenText TextStyle="TextStyle.Caption" class="muted-text">
                                            @ev.Date.ToString("dd.MM.yyyy HH:mm")
                                        </RadzenText>
                                    </RadzenStack>

                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.35rem">
                                        <RadzenIcon Icon="place" class="tiny-icon" />
                                        <RadzenText TextStyle="TextStyle.Caption" class="muted-text">
                                            @ev.Location
                                        </RadzenText>
                                    </RadzenStack>
                                </RadzenStack>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Category">
                        <Template Context="ev">
                            <RadzenBadge Text="@ev.Category"
                                         Variant="Variant.Flat"
                                         Shade="Shade.Lighter"
                                         class="category-badge" />
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Created By">
                        <Template Context="ev">
                            <RadzenText TextStyle="TextStyle.Body2">@ev.CreatorName</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Status">
                        <Template Context="ev">
                            <span class="@GetStatusPillClass(ev.Status)">
                                @GetStatusLabel(ev.Status)
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Admin Note">
                        <Template Context="ev">
                            <RadzenStack Gap="0.45rem">
                                <RadzenTextBox Value="@GetAdminNoteValue(ev.Id)"
                                               Placeholder="Write admin note..."
                                               Style="width: 100%;"
                                               Change="@(args => UpdateAdminNoteInput(ev.Id, args?.ToString() ?? string.Empty))"
                                               class="note-input" />

                                @if (!string.IsNullOrWhiteSpace(ev.AdminNote))
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" class="saved-note">
                                        Saved: @ev.AdminNote
                                    </RadzenText>
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AdminEventListItem" Title="Actions">
                        <Template Context="ev">
                            <RadzenWrap Gap="1rem">
                                <RadzenButton Icon="visibility"
                                              ButtonStyle="ButtonStyle.Info"
                                              Variant="Variant.Outlined"
                                              Size="ButtonSize.Small"
                                              Click='@(() => NavigationManager.NavigateTo($"/events/{ev.Id}"))'
                                              class="action-button"
                                              title="View" />

                                @if (ev.Status == "Active" || ev.Status == "Hidden" || ev.Status == "PendingReview")
                                {
                                    <RadzenButton Icon="flag"
                                                  ButtonStyle="ButtonStyle.Warning"
                                                  Variant="Variant.Filled"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => FlagEvent(ev.Id))'
                                                  class="action-button"
                                                  title="Flag" />
                                }

                                @if (ev.Status == "Flagged")
                                {
                                    <RadzenButton Icon="save"
                                                  ButtonStyle="ButtonStyle.Warning"
                                                  Variant="Variant.Outlined"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => UpdateFlaggedNote(ev.Id))'
                                                  class="action-button"
                                                  title="Update note" />
                                }

                                @if (ev.Status != "Hidden")
                                {
                                    <RadzenButton Icon="visibility_off"
                                                  ButtonStyle="ButtonStyle.Secondary"
                                                  Variant="Variant.Filled"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => UpdateStatus(ev.Id, "Hidden"))'
                                                  class="action-button"
                                                  title="Hide" />
                                }

                                @if (ev.Status != "Active")
                                {
                                    <RadzenButton Icon="restart_alt"
                                                  ButtonStyle="ButtonStyle.Success"
                                                  Variant="Variant.Filled"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@isProcessing"
                                                  Click='@(() => UpdateStatus(ev.Id, "Active"))'
                                                  class="action-button"
                                                  title="Restore" />
                                }
                            </RadzenWrap>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    }
</RadzenStack>

<style>
