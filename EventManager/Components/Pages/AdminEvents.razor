</style>

@code {
    private List<AdminEventListItem> events = new();
    private Dictionary<int, string> adminNotes = new();

    private bool isLoading = true;
    private bool isProcessing;

    private string? Message;
    private string messageCss = "alert-success";

    private string searchTerm = string.Empty;
    private string selectedStatus = string.Empty;
    private string selectedSort = "date_asc";

    private readonly List<OptionItem> statusOptions = new()
    {
        new() { Text = "All statuses", Value = "" },
        new() { Text = "Active", Value = "Active" },
        new() { Text = "Flagged", Value = "Flagged" },
        new() { Text = "Hidden", Value = "Hidden" },
        new() { Text = "Pending Review", Value = "PendingReview" }
    };

    private readonly List<OptionItem> sortOptions = new()
    {
        new() { Text = "Date: Soonest First", Value = "date_asc" },
        new() { Text = "Date: Latest First", Value = "date_desc" },
        new() { Text = "Title: A-Z", Value = "title_asc" },
        new() { Text = "Title: Z-A", Value = "title_desc" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;

        events = await AdminService.GetAllEventsForAdminAsync();

        adminNotes.Clear();
        foreach (var ev in events)
        {
            adminNotes[ev.Id] = ev.AdminNote ?? string.Empty;
        }

        isLoading = false;
    }

    private List<AdminEventListItem> FilteredEvents
    {
        get
        {
            IEnumerable<AdminEventListItem> query = events;

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                query = query.Where(e =>
                    (e.Title?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Location?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Category?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            if (!string.IsNullOrWhiteSpace(selectedStatus))
            {
                query = query.Where(e => e.Status == selectedStatus);
            }

            query = selectedSort switch
            {
                "date_desc" => query.OrderByDescending(e => e.Date),
                "title_asc" => query.OrderBy(e => e.Title),
                "title_desc" => query.OrderByDescending(e => e.Title),
                _ => query.OrderBy(e => e.Date)
            };

            return query.ToList();
        }
    }

    private string GetAdminNoteValue(int eventId)
    {
        return adminNotes.TryGetValue(eventId, out var value) ? value : string.Empty;
    }

    private void UpdateAdminNoteInput(int eventId, string value)
    {
        adminNotes[eventId] = value;
    }

    private async Task FlagEvent(int eventId)
    {
        isProcessing = true;
        ClearMessage();

        var note = adminNotes.TryGetValue(eventId, out var value)
            ? value?.Trim() ?? string.Empty
            : string.Empty;

        var result = await AdminService.FlagEventAsync(eventId, note);

        if (result.Success)
        {
            ShowSuccess(result.Message);
            await LoadEvents();
        }
        else
        {
            ShowError(result.Message);
        }

        isProcessing = false;
    }

    private async Task UpdateFlaggedNote(int eventId)
    {
        isProcessing = true;
        ClearMessage();

        var note = adminNotes.TryGetValue(eventId, out var value)
            ? value?.Trim() ?? string.Empty
            : string.Empty;

        var result = await AdminService.UpdateFlaggedNoteAsync(eventId, note);

        if (result.Success)
        {
            ShowSuccess(result.Message);
            await LoadEvents();
        }
        else
        {
            ShowError(result.Message);
        }

        isProcessing = false;
    }

    private async Task UpdateStatus(int eventId, string newStatus)
    {
        isProcessing = true;
        ClearMessage();

        var result = await AdminService.UpdateEventStatusAsync(eventId, newStatus);

        if (result.Success)
        {
            if (newStatus != "Flagged")
            {
                adminNotes[eventId] = string.Empty;
            }

            ShowSuccess(result.Message);
            await LoadEvents();
        }
        else
        {
            ShowError(result.Message);
        }

        isProcessing = false;
    }

    private string GetStatusLabel(string status) => status switch
    {
        "PendingReview" => "Pending Review",
        _ => status
    };

    private string GetStatusPillClass(string status) => status switch
    {
        "Active" => "status-pill status-active",
        "Flagged" => "status-pill status-flagged",
        "PendingReview" => "status-pill status-pending",
        "Hidden" => "status-pill status-hidden",
        _ => "status-pill status-default"
    };

    private void ClearFilters()
    {
        searchTerm = string.Empty;
        selectedStatus = string.Empty;
        selectedSort = "date_asc";
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        messageCss = "alert-success";
    }

    private void ShowError(string message)
    {
        Message = message;
        messageCss = "alert-danger";
    }

    private void ClearMessage()
    {
        Message = null;
    }

    private class OptionItem
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}