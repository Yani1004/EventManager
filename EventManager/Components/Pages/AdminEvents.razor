    .metric-card,
    .filters-panel,
    .grid-shell,
    .state-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .events-hero-card {
        padding: 0.6rem;
        background: radial-gradient(circle at top left, rgba(255,255,255,0.22), transparent 30%),
                    linear-gradient(135deg, #1e3a8a 0%, #2563eb 45%, #4f46e5 100%);
    }

    .hero-icon-wrap {
        width: 72px;
        height: 72px;
        min-width: 72px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.16);
    }

    .hero-main-icon {
        font-size: 2rem;
        color: white;
    }

    .hero-title {
        color: white;
        font-weight: 800;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.88);
    }

    .back-button {
