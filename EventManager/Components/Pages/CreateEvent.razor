@page "/events/create"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "EventManager")]

@using System.Globalization
@using System.Security.Claims
@using Radzen
@using Radzen.Blazor
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Create Event</PageTitle>

<div class="create-event-page">
    <div class="create-event-container">
        <RadzenCard class="create-event-shell">
            <RadzenStack Gap="1.5rem">

                <div class="create-event-header">
                    <div class="badge-wrap">
                        <RadzenBadge Text="Event Manager" Shade="Shade.Light" Variant="Variant.Flat" class="section-badge" />
                    </div>

                    <h1>Create a New Event</h1>
                    <p class="subtitle">
                        Publish an engaging event with all the important details for your audience.
                    </p>
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <RadzenAlert AlertStyle="@alertStyle"
                                 Variant="Variant.Flat"
                                 Shade="Shade.Light"
                                 ShowIcon="true"
                                 class="custom-alert">
                        @message
                    </RadzenAlert>
                }

                @if (!string.IsNullOrWhiteSpace(dateValidationMessage))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger"
                                 Variant="Variant.Flat"
                                 Shade="Shade.Light"
                                 ShowIcon="true"
                                 class="custom-alert">
                        @dateValidationMessage
                    </RadzenAlert>
                }

                <RadzenTemplateForm TItem="Event" Data="@eventModel" Submit="@HandleCreateEvent">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-summary" />

                    <RadzenStack Gap="1.25rem">

                        <RadzenCard class="form-section">
                            <RadzenStack Gap="1rem">
                                <div class="section-title">
                                    <div class="section-icon">
                                        <i class="bi bi-pencil-square"></i>
                                    </div>
                                    <h4>Basic Information</h4>
                                </div>

                                <RadzenStack Gap="0.35rem">
                                    <label class="form-label">Title</label>
                                    <RadzenTextBox Name="Title"
                                                   @bind-Value="eventModel.Title"
                                                   Placeholder="Enter event title"
                                                   Style="width: 100%;"
                                                   class="rz-field" />
                                    <ValidationMessage For="@(() => eventModel.Title)" class="validation-text" />
                                </RadzenStack>

                                <RadzenStack Gap="0.35rem">
                                    <label class="form-label">Description</label>
                                    <RadzenTextArea Name="Description"
                                                    @bind-Value="eventModel.Description"
                                                    Placeholder="Describe your event"
                                                    Rows="6"
                                                    Style="width: 100%;"
                                                    class="rz-field" />
                                    <ValidationMessage For="@(() => eventModel.Description)" class="validation-text" />
                                </RadzenStack>

                                <RadzenStack Gap="0.35rem">
                                    <label class="form-label">Category</label>
                                    <RadzenDropDown Name="Category"
                                                    Data="@categories"
                                                    @bind-Value="eventModel.Category"
                                                    Placeholder="Select a category"
                                                    AllowClear="true"
                                                    Style="width: 100%;"
                                                    class="rz-field" />
                                    <ValidationMessage For="@(() => eventModel.Category)" class="validation-text" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenCard>

                        <RadzenCard class="form-section">
                            <RadzenStack Gap="1rem">
                                <div class="section-title">
                                    <div class="section-icon">
                                        <i class="bi bi-calendar-event"></i>
                                    </div>
                                    <h4>Schedule & Capacity</h4>
                                </div>

                                <RadzenRow Gap="16px">
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenStack Gap="0.35rem">
                                            <label class="form-label">Date</label>
                                            <RadzenDatePicker Name="EventDateInput"
                                                              @bind-Value="eventDateOnly"
                                                              DateFormat="dd.MM.yyyy"
                                                              Min="@minimumEventDate.Date"
                                                              Culture="@englishCulture"
                                                              Style="width: 100%;"
                                                              class="rz-field" />
                                        </RadzenStack>
                                    </RadzenColumn>

                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenStack Gap="0.35rem">
                                            <label class="form-label">Time</label>
                                            <RadzenDropDown Name="EventTimeInput"
                                                            Data="@timeOptions"
                                                            TextProperty="Label"
                                                            ValueProperty="Value"
                                                            @bind-Value="selectedTime"
                                                            Placeholder="Select time"
                                                            AllowClear="false"
                                                            Style="width: 100%;"
                                                            class="rz-field time-dropdown" />
                                        </RadzenStack>
                                    </RadzenColumn>

                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenStack Gap="0.35rem">
                                            <label class="form-label">Capacity</label>
                                            <RadzenNumeric Name="Capacity"
                                                           TValue="int"
                                                           @bind-Value="eventModel.Capacity"
                                                           Min="1"
                                                           Step="1"
                                                           Placeholder="Enter capacity"
                                                           Style="width: 100%;"
                                                           class="rz-field" />
                                            <ValidationMessage For="@(() => eventModel.Capacity)" class="validation-text" />
                                        </RadzenStack>
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenStack>
                        </RadzenCard>

                        <RadzenCard class="form-section">
                            <RadzenStack Gap="1rem">
                                <div class="section-title">
                                    <div class="section-icon">
                                        <i class="bi bi-cash-coin"></i>
                                    </div>
                                    <h4>Pricing & Media</h4>
                                </div>

                                <RadzenRow Gap="16px">
                                    <RadzenColumn Size="12" SizeMD="6">
                                        <RadzenStack Gap="0.35rem">
                                            <label class="form-label">Price</label>
                                            <RadzenNumeric TValue="decimal"
                                                           Name="Price"
                                                           @bind-Value="eventModel.Price"
                                                           Min="0"
                                                           Step="0.01"
                                                           Format="0.00"
                                                           Placeholder="Enter price"
                                                           Style="width: 100%;"
                                                           class="rz-field" />
                                            <ValidationMessage For="@(() => eventModel.Price)" class="validation-text" />
                                            <small class="form-helper">Set 0 if this is a free event.</small>
                                        </RadzenStack>
                                    </RadzenColumn>

                                    <RadzenColumn Size="12" SizeMD="6">
                                        <RadzenStack Gap="0.35rem">
                                            <label class="form-label">Image URL</label>
                                            <RadzenTextBox Name="ImageUrl"
                                                           @bind-Value="eventModel.ImageUrl"
                                                           Placeholder="Paste image URL"
                                                           Style="width: 100%;"
                                                           class="rz-field" />
                                            <ValidationMessage For="@(() => eventModel.ImageUrl)" class="validation-text" />
                                        </RadzenStack>
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenStack>
                        </RadzenCard>

                        <RadzenCard class="form-section">
                            <RadzenStack Gap="1rem">
                                <div class="section-title">
                                    <div class="section-icon">
                                        <i class="bi bi-geo-alt"></i>
                                    </div>
                                    <h4>Location</h4>
                                </div>

                                <RadzenStack Gap="0.35rem">
                                    <label class="form-label">Venue / Address</label>
                                    <RadzenTextBox Name="Location"
                                                   Value="@eventModel.Location"
                                                   Change="@OnLocationChanged"
                                                   Placeholder="Enter city, venue, or full address"
                                                   Style="width: 100%;"
                                                   class="rz-field" />
                                    <ValidationMessage For="@(() => eventModel.Location)" class="validation-text" />

                                </RadzenStack>

                                @if (!string.IsNullOrWhiteSpace(eventModel.Location))
                                {
                                    <RadzenCard class="preview-card">
                                        <div class="preview-card-header">
                                            <div>
                                                <h5>Location Preview</h5>
                                                <p>Check how the address looks on the map.</p>
                                            </div>

                                            <RadzenButton Text="Open in Google Maps"
                                                          Icon="open_in_new"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Variant="Variant.Outlined"
                                                          Size="ButtonSize.Small"
                                                          Click="@OpenGoogleMaps" />
                                        </div>

                                        <div class="map-wrapper">
                                            <iframe src="@googleMapsEmbedUrl"
                                                    height="320"
                                                    class="preview-frame"
                                                    allowfullscreen
                                                    loading="lazy">
                                            </iframe>
                                        </div>
                                    </RadzenCard>
                                }
                            </RadzenStack>
                        </RadzenCard>

                        @if (!string.IsNullOrWhiteSpace(eventModel.ImageUrl))
                        {
                            <RadzenCard class="form-section">
                                <RadzenStack Gap="1rem">
                                    <div class="section-title">
                                        <div class="section-icon">
                                            <i class="bi bi-image"></i>
                                        </div>
                                        <h4>Image Preview</h4>
                                    </div>

                                    <RadzenCard class="preview-card">
                                        <img src="@eventModel.ImageUrl"
                                             alt="Event preview"
                                             class="preview-image" />
                                    </RadzenCard>
                                </RadzenStack>
                            </RadzenCard>
                        }

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     Gap="1rem"
                                     JustifyContent="JustifyContent.End"
                                     AlignItems="AlignItems.Center"
                                     Wrap="FlexWrap.Wrap"
                                     class="action-bar">

                            <RadzenButton ButtonType="ButtonType.Submit"
                                          Text="@(isSubmitting ? "Creating Event..." : "Create Event")"
                                          Icon="check_circle"
                                          IsBusy="@isSubmitting"
                                          BusyText="Creating..."
                                          Size="ButtonSize.Large"
                                          class="create-btn" />

                            <RadzenButton Text="Cancel"
                                          Icon="close"
                                          ButtonStyle="ButtonStyle.Light"
                                          Variant="Variant.Outlined"
                                          Size="ButtonSize.Large"
                                          Click="@GoBack"
                                          Disabled="@isSubmitting"
                                          class="cancel-btn" />
                        </RadzenStack>
                    </RadzenStack>
                </RadzenTemplateForm>
            </RadzenStack>
        </RadzenCard>
    </div>
</div>

@code {
    private readonly CultureInfo englishCulture = new("en-US");

    private Event eventModel = new();
    private bool isSubmitting = false;

    private string message = string.Empty;
    private string dateValidationMessage = string.Empty;

    private string googleMapsSearchUrl = string.Empty;
    private string googleMapsEmbedUrl = string.Empty;

    private DateTime minimumEventDate => DateTime.Now;

    private AlertStyle alertStyle = AlertStyle.Info;

    private DateTime eventDateOnly = DateTime.Today.AddDays(1);
    private string selectedTime = "18:00";

    private readonly List<string> categories = new()
    {
        "Conference",
        "Workshop",
        "Concert",
        "Sports",
        "Networking",
        "Festival",
        "Seminar",
        "Other"
    };

    private readonly List<TimeOption> timeOptions = GenerateTimeOptions();

    protected override void OnInitialized()
    {
        eventDateOnly = DateTime.Today.AddDays(1);
        selectedTime = "18:00";

        eventModel.Date = CombineDateAndTime(eventDateOnly, selectedTime);
        eventModel.Status = "Active";
        eventModel.AdminNote = null;

        UpdateMapUrl();
    }

    private void OnLocationChanged(object value)
    {
        eventModel.Location = value?.ToString() ?? string.Empty;
        UpdateMapUrl();
    }

    private void UpdateMapUrl()
    {
        var location = eventModel.Location ?? string.Empty;
        var encodedLocation = Uri.EscapeDataString(location);

        googleMapsSearchUrl = $"https://www.google.com/maps/search/?api=1&query={encodedLocation}";
        googleMapsEmbedUrl = $"https://www.google.com/maps?q={encodedLocation}&output=embed";
    }

    private void OpenGoogleMaps()
    {
        NavigationManager.NavigateTo(googleMapsSearchUrl, forceLoad: true);
    }

    private async Task HandleCreateEvent()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        message = string.Empty;
        dateValidationMessage = string.Empty;
        alertStyle = AlertStyle.Info;

        try
        {
            eventModel.Date = CombineDateAndTime(eventDateOnly, selectedTime);

            if (eventModel.Date <= DateTime.Now)
            {
                dateValidationMessage = "Event date and time must be in the future.";
                alertStyle = AlertStyle.Danger;
                return;
            }

            UpdateMapUrl();

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                message = "Could not identify the current user.";
                alertStyle = AlertStyle.Danger;
                return;
            }

            eventModel.CreatorId = userId;
            eventModel.CreatedAt = DateTime.UtcNow;
            eventModel.Status = "Active";
            eventModel.AdminNote = null;

            var localEventDate = DateTime.SpecifyKind(eventModel.Date, DateTimeKind.Local);
            eventModel.Date = localEventDate.ToUniversalTime();

            Db.Events.Add(eventModel);
            await Db.SaveChangesAsync();

            message = "Event created successfully.";
            alertStyle = AlertStyle.Success;

            await Task.Delay(600);
            NavigationManager.NavigateTo("/my-events");
        }
        catch (Exception ex)
        {
            message = ex.Message;
            alertStyle = AlertStyle.Danger;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/events");
    }

    private static DateTime CombineDateAndTime(DateTime date, string time)
    {
        if (TimeSpan.TryParse(time, out var parsedTime))
        {
            return date.Date.Add(parsedTime);
        }

        return date.Date.AddHours(18);
    }

    private static List<TimeOption> GenerateTimeOptions()
    {
        var result = new List<TimeOption>();

        for (int hour = 0; hour < 24; hour++)
        {
            foreach (var minute in new[] { 0, 30 })
            {
                var time = new TimeSpan(hour, minute, 0);
                var label = time.ToString(@"hh\:mm");

                result.Add(new TimeOption
                {
                    Value = label,
                    Label = label
                });
            }
        }

        return result;
    }

    private class TimeOption
    {
        public string Value { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
    }
}