@page "/my-registrations"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Attendee")]

@using System.Security.Claims
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>My Registrations</PageTitle>

<div class="my-registrations-page">
    <RadzenStack Gap="1.5rem" class="page-stack">

        <RadzenCard class="page-header-card">
            <RadzenStack Orientation="Orientation.Horizontal"
                         JustifyContent="JustifyContent.SpaceBetween"
                         AlignItems="AlignItems.Center"
                         Wrap="FlexWrap.Wrap"
                         Gap="1rem">
                <RadzenStack Gap="0.35rem">
                    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="page-title">
                        My Registrations
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" class="page-subtitle">
                        View the events you joined and manage your registrations in one place.
                    </RadzenText>
                </RadzenStack>

                <RadzenButton Text="Browse Events"
                              Icon="explore"
                              Size="ButtonSize.Large"
                              class ="rdz-btn"
                              Click='@(() => NavigationManager.NavigateTo("/events"))' />
            </RadzenStack>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <RadzenAlert AlertStyle="@messageStyle"
                         Variant="Variant.Flat"
                         Shade="Shade.Light"
                         class="feedback-alert">
                @message
            </RadzenAlert>
        }

        @if (isLoading)
        {
            <RadzenCard class="state-card">
                <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="state-stack">
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.Body1">Loading registrations...</RadzenText>
                </RadzenStack>
            </RadzenCard>
        }
        else if (!registrations.Any())
        {
            <RadzenCard class="empty-card">
                <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="state-stack">
                    <div class="empty-icon-wrap">
                        <RadzenIcon Icon="confirmation_number" class="empty-icon" />
                    </div>

                    <RadzenText TextStyle="TextStyle.H5" class="empty-title">
                        No registrations yet
                    </RadzenText>

                    <RadzenText TextStyle="TextStyle.Body1" class="empty-text">
                        You have not registered for any events yet. Explore upcoming events and join the ones you like.
                    </RadzenText>

                    <RadzenButton Text="Explore Events"
                                  Icon="travel_explore"
                                  Size="ButtonSize.Medium"
                                  class ="rdz-btn"
                                  Click='@(() => NavigationManager.NavigateTo("/events"))' />
                </RadzenStack>
            </RadzenCard>
        }
        else
        {
            <RadzenRow Gap="1.5rem" RowGap="1.5rem" class="cards-row">
                @foreach (var reg in registrations)
                {
                    <RadzenColumn Size="12" SizeMD="6" SizeXL="4">
                        <RadzenCard class="registration-card">
                            <RadzenStack Gap="0" class="registration-card-stack">
                                <div class="image-wrap">
                                    <img src="@(string.IsNullOrWhiteSpace(reg.Event?.ImageUrl) ? "https://via.placeholder.com/400x220?text=No+Image" : reg.Event!.ImageUrl)"
                                         alt="@reg.Event?.Title"
                                         class="registration-image" />
                                    <RadzenBadge Text="@reg.Event?.EventCategory?.Name"
                                                 class="category-badge" />
                                </div>

                                <RadzenStack Gap="0.85rem" class="registration-content">
                                    <RadzenStack Gap="0.35rem">
                                        <RadzenText TextStyle="TextStyle.H6" class="event-title">
                                            @reg.Event?.Title
                                        </RadzenText>

                                        <RadzenText TextStyle="TextStyle.Body2" class="description-text">
                                            Registered event details and quick actions.
                                        </RadzenText>
                                    </RadzenStack>

                                    <RadzenStack Gap="0.7rem" class="details-stack">
                                        <RadzenStack Orientation="Orientation.Horizontal"
                                                     AlignItems="AlignItems.Start"
                                                     Gap="0.65rem">
                                            <div class="detail-icon-wrap">
                                                <RadzenIcon Icon="calendar_month" class="detail-icon" />
                                            </div>
                                            <RadzenStack Gap="0.15rem">
                                                <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Event Date</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                    @reg.Event?.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenStack>

                                        <RadzenStack Orientation="Orientation.Horizontal"
                                                     AlignItems="AlignItems.Start"
                                                     Gap="0.65rem">
                                            <div class="detail-icon-wrap">
                                                <RadzenIcon Icon="place" class="detail-icon" />
                                            </div>
                                            <RadzenStack Gap="0.15rem">
                                                <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Location</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                    @reg.Event?.Location
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenStack>

                                        <RadzenStack Orientation="Orientation.Horizontal"
                                                     AlignItems="AlignItems.Start"
                                                     Gap="0.65rem">
                                            <div class="detail-icon-wrap">
                                                <RadzenIcon Icon="how_to_reg" class="detail-icon" />
                                            </div>
                                            <RadzenStack Gap="0.15rem">
                                                <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Registered On</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                    @reg.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenStack>
                                    </RadzenStack>

                                    <RadzenStack Orientation="Orientation.Horizontal"
                                                 Gap="0.75rem"
                                                 Wrap="FlexWrap.Wrap"
                                                 class="actions-row">
                                        <RadzenButton Text="View Event"
                                                      Icon="visibility"
                                                      Variant="Variant.Outlined"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      class="action-button"
                                                      Click='@(() => NavigationManager.NavigateTo($"/events/{reg.EventId}"))' />

                                        <RadzenButton Text="Cancel"
                                                      Icon="close"
                                                      Variant="Variant.Outlined"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      class="action-button"
                                                      Click='@(() => CancelRegistration(reg.Id))' />
                                    </RadzenStack>
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenCard>
                    </RadzenColumn>
                }
            </RadzenRow>
        }
    </RadzenStack>
</div>

<style>
    .my-registrations-page {
        padding: 1.5rem;
    }

    .page-stack {
        max-width: 88rem;
        margin: 0 auto;
    }
    .rdz-btn{
        border-radius:14px;
    }
    .page-header-card,
    .state-card,
    .empty-card,
    .registration-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 1.125rem 2.8125rem rgba(15, 23, 42, 0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
    }

    .page-header-card {
        padding: 0.5rem;
    }

    .page-title {
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .page-subtitle {
        color: #64748b;
    }

    .feedback-alert {
        border-radius: 1rem;
    }

    .state-card,
    .empty-card {
        padding: 1.5rem;
    }

    .state-stack {
        padding: 1rem 0;
    }

    .empty-icon-wrap {
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.10);
    }

    .empty-icon {
        font-size: 2rem;
        color: #2563eb;
    }

    .empty-title {
        font-weight: 700;
        color: #0f172a;
    }

    .empty-text {
        color: #64748b;
        text-align: center;
        max-width: 32rem;
    }

    .cards-row {
        margin: 0;
    }

    .registration-card {
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        height: 100%;
    }

    .registration-card:hover {
        transform: translateY(-0.25rem);
        box-shadow: 0 1.5rem 3rem rgba(15, 23, 42, 0.12);
    }

    .registration-card-stack {
        height: 100%;
    }

    .image-wrap {
        position: relative;
    }

    .registration-image {
        width: 100%;
        height: 14rem;
        object-fit: cover;
        display: block;
    }

    .category-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        border-radius: 999rem;
        padding: 0.4rem 0.8rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.92) !important;
        color: #0f172a !important;
        box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.12);
    }

    .registration-content {
        padding: 1.25rem;
        flex: 1;
        justify-content: space-between;
        min-height: 17rem;
    }

    .event-title {
        font-weight: 700;
        color: #0f172a;
        line-height: 1.3;
    }

    .description-text {
        color: #64748b;
        line-height: 1.5;
    }

    .details-stack {
        padding-top: 0.25rem;
    }

    .detail-icon-wrap {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 0.85rem;
        background: rgba(37, 99, 235, 0.10);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .detail-icon {
        color: #2563eb;
        font-size: 1.1rem;
    }

    .detail-label {
        color: #64748b;
        font-weight: 600;
    }

    .detail-value {
        color: #0f172a;
        font-weight: 500;
        word-break: break-word;
    }

    .actions-row {
        margin-top: auto;
    }

    .action-button {
        flex: 1 1 10rem;
        justify-content: center;
    }

    @@media (max-width: 75rem) {
        .my-registrations-page {
            padding: 1rem;
        }

        .page-stack {
            max-width: 100%;
        }
    }

    @@media (max-width: 40rem) {
        .registration-image {
            height: 12rem;
        }

        .registration-content {
            padding: 1rem;
            min-height: auto;
        }
    }
</style>

@code {
    private List<Registration> registrations = new();
    private bool isLoading = true;

    private string message = string.Empty;
    private AlertStyle messageStyle = AlertStyle.Info;

    protected override async Task OnInitializedAsync()
    {
        await LoadRegistrations();
    }

    private async Task LoadRegistrations()
    {
        isLoading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(userId))
        {
            registrations = await Db.Registrations
                .Include(r => r.Event)
                    .ThenInclude(e => e.EventCategory)
                .Include(r => r.Event)
                    .ThenInclude(e => e.EventStatus)
                .Where(r => r.UserId == userId)
                .OrderByDescending(r => r.RegisteredAt)
                .ToListAsync();
        }
        else
        {
            registrations = new List<Registration>();
        }

        isLoading = false;
    }

    private async Task CancelRegistration(int registrationId)
    {
        message = string.Empty;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            message = "Could not identify the current user.";
            messageStyle = AlertStyle.Danger;
            return;
        }

        var registration = await Db.Registrations
            .FirstOrDefaultAsync(r => r.Id == registrationId && r.UserId == userId);

        if (registration == null)
        {
            message = "Registration not found.";
            messageStyle = AlertStyle.Danger;
            return;
        }

        Db.Registrations.Remove(registration);
        await Db.SaveChangesAsync();

        message = "Registration cancelled successfully.";
        messageStyle = AlertStyle.Success;

        await LoadRegistrations();
    }
}