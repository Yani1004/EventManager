@page "/my-registrations"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Attendee")]

@using System.Security.Claims
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>My Registrations</PageTitle>

<div class="container py-4">
    <h1 class="mb-4">My Registrations</h1>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageCss mb-4">@message</div>
    }

    @if (isLoading)
    {
        <p>Loading registrations...</p>
    }
    else if (!registrations.Any())
    {
        <div class="alert alert-info">
            You have not registered for any events yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var reg in registrations)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card registration-card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrWhiteSpace(reg.Event?.ImageUrl) ? "https://via.placeholder.com/400x220?text=No+Image" : reg.Event.ImageUrl)"
                             class="card-img-top registration-image"
                             alt="@reg.Event?.Title" />

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                <h5 class="card-title mb-0">@reg.Event?.Title</h5>
                                <span class="badge bg-light text-dark category-badge">@reg.Event?.Category</span>
                            </div>

                            <p class="text-muted mb-2">
                                <strong>Date:</strong> @reg.Event?.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </p>

                            <p class="text-muted mb-2">
                                <strong>Location:</strong> @reg.Event?.Location
                            </p>

                            <p class="text-muted mb-3">
                                <strong>Registered:</strong> @reg.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </p>

                            <div class="mt-auto d-flex gap-2">
                                <a class="btn btn-outline-primary flex-fill" href="/events/@reg.EventId">
                                    View Event
                                </a>

                                <button class="btn btn-outline-danger flex-fill"
                                        @onclick="() => CancelRegistration(reg.Id)">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .registration-card {
        border-radius: 16px;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .registration-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12) !important;
        }

    .registration-image {
        height: 220px;
        object-fit: cover;
    }

    .category-badge {
        border-radius: 999px;
        font-weight: 500;
        padding: 0.45rem 0.7rem;
        white-space: nowrap;
    }
</style>

@code {
    private List<Registration> registrations = new();
    private bool isLoading = true;

    private string message = string.Empty;
    private string messageCss = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadRegistrations();
    }

    private async Task LoadRegistrations()
    {
        isLoading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(userId))
        {
            registrations = await Db.Registrations
                .Include(r => r.Event)
                .Where(r => r.UserId == userId)
                .OrderByDescending(r => r.RegisteredAt)
                .ToListAsync();
        }
        else
        {
            registrations = new List<Registration>();
        }

        isLoading = false;
    }

    private async Task CancelRegistration(int registrationId)
    {
        message = string.Empty;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            message = "Could not identify the current user.";
            messageCss = "alert-danger";
            return;
        }

        var registration = await Db.Registrations
            .FirstOrDefaultAsync(r => r.Id == registrationId && r.UserId == userId);

        if (registration == null)
        {
            message = "Registration not found.";
            messageCss = "alert-danger";
            return;
        }

        Db.Registrations.Remove(registration);
        await Db.SaveChangesAsync();

        message = "Registration cancelled successfully.";
        messageCss = "alert-success";

        await LoadRegistrations();
    }
}