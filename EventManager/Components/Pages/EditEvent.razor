@page "/events/edit/{Id:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "EventManager")]

@using System.Globalization
@using System.Security.Claims
@using Radzen
@using Radzen.Blazor
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Edit Event</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 create-event-card">
                <div class="card-body p-4 p-md-5">
                    <h1 class="mb-2">Edit Event</h1>
                    <p class="text-muted mb-4">Update your event details below.</p>

                    @if (isLoading)
                    {
                        <p>Loading event...</p>
                    }
                    else if (eventModel == null)
                    {
                        <div class="alert alert-warning">
                            Event not found or access denied.
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(message))
                        {
                            <div class="alert @messageCss mb-4">@message</div>
                        }

                        <EditForm Model="eventModel" OnValidSubmit="HandleEditEvent" FormName="editEventForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="mb-3 text-danger" />

                            <div class="mb-3">
                                <label class="form-label">Title</label>
                                <InputText class="form-control" @bind-Value="eventModel.Title" />
                                <ValidationMessage For="@(() => eventModel.Title)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" @bind-Value="eventModel.Description" />
                                <ValidationMessage For="@(() => eventModel.Description)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Category</label>
                                <InputSelect class="form-select" @bind-Value="eventModel.Category">
                                    <option value="">Select a category</option>
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => eventModel.Category)" class="text-danger" />
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Date and Time</label>
                                    <RadzenDatePicker Name="EventDateInput"
                                                      @bind-Value="eventModel.Date"
                                                      ShowTime="true"
                                                      DateFormat="dd.MM.yyyy HH:mm"
                                                      Min="@minimumEventDate"
                                                      Culture="@englishCulture"
                                                      Class="w-100 event-datepicker" />

                                    @if (!string.IsNullOrWhiteSpace(dateValidationMessage))
                                    {
                                        <div class="text-danger mt-1">@dateValidationMessage</div>
                                    }
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Capacity</label>
                                    <InputNumber class="form-control" @bind-Value="eventModel.Capacity" />
                                    <ValidationMessage For="@(() => eventModel.Capacity)" class="text-danger" />
                                </div>
                            </div>

                            <div class="row g-3 mt-1">
                                <div class="col-md-6">
                                    <label class="form-label">Price</label>
                                    <InputNumber class="form-control" @bind-Value="eventModel.Price" />
                                    <ValidationMessage For="@(() => eventModel.Price)" class="text-danger" />
                                    <div class="form-text">Use 0 for free events.</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Image URL</label>
                                    <InputText class="form-control" @bind-Value="eventModel.ImageUrl" />
                                    <ValidationMessage For="@(() => eventModel.ImageUrl)" class="text-danger" />
                                </div>
                            </div>

                            <div class="mb-3 mt-3">
                                <label class="form-label">Location</label>
                                <input class="form-control"
                                       value="@eventModel.Location"
                                       @oninput="OnLocationChanged" />
                                <ValidationMessage For="@(() => eventModel.Location)" class="text-danger" />
                                <div class="form-text">Enter city, venue, or full address.</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(eventModel.Location))
                            {
                                <div class="map-preview-box mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Location Preview</strong>
                                        <a class="btn btn-sm btn-outline-primary" href="@googleMapsSearchUrl" target="_blank">
                                            Open in Google Maps
                                        </a>
                                    </div>

                                    <iframe src="@googleMapsEmbedUrl"
                                            height="260"
                                            style="border:0; border-radius:12px; width:100%;"
                                            allowfullscreen
                                            loading="lazy">
                                    </iframe>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(eventModel.ImageUrl))
                            {
                                <div class="image-preview-box mb-4">
                                    <strong class="d-block mb-2">Image Preview</strong>
                                    <img src="@eventModel.ImageUrl"
                                         alt="Event preview"
                                         class="img-fluid rounded preview-image" />
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary btn-lg" disabled="@isSubmitting">
                                    @(isSubmitting ? "Saving..." : "Save Changes")
                                </button>

                                <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="GoBack">
                                    Cancel
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .create-event-card {
        border-radius: 20px;
    }

    .map-preview-box,
    .image-preview-box {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 16px;
        padding: 1rem;
    }

    .preview-image {
        max-height: 280px;
        width: 100%;
        object-fit: cover;
    }

    .create-event-card .form-control,
    .create-event-card .form-select {
        min-height: 48px;
        height: 48px;
        border: 1px solid #ced4da !important;
        border-radius: 12px !important;
        box-shadow: none !important;
        font-size: 1rem;
        padding: 0.75rem 1rem;
    }

    .create-event-card textarea.form-control {
        min-height: 170px;
        height: 170px;
        resize: vertical;
        padding-top: 0.9rem;
    }

    .create-event-card .form-control:focus,
    .create-event-card .form-select:focus {
        border-color: #86b7fe !important;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15) !important;
    }

    .create-event-card .rz-datepicker {
        width: 100%;
        display: block;
    }

    .create-event-card .rz-inputtext {
        width: 100%;
        min-height: 48px !important;
        height: 48px !important;
        border: 1px solid #ced4da !important;
        border-radius: 12px !important;
        box-shadow: none !important;
        background-color: #fff !important;
        color: #212529 !important;
        font-size: 1rem;
        padding: 0.75rem 3rem 0.75rem 1rem !important;
    }

        .create-event-card .rz-inputtext:focus,
        .create-event-card .rz-state-focus .rz-inputtext,
        .create-event-card .rz-datepicker:focus-within .rz-inputtext {
            border-color: #86b7fe !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15) !important;
            outline: none !important;
        }

    .create-event-card .rz-datepicker-trigger {
        color: #6c757d !important;
        background: transparent !important;
        border: none !important;
        width: 48px !important;
        min-width: 48px !important;
        display: flex !important;
        align-items: center;
        justify-content: center;
    }

        .create-event-card .rz-datepicker-trigger:hover {
            color: #495057 !important;
            background: transparent !important;
        }

    .create-event-card .text-danger {
        font-size: 0.92rem;
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private readonly CultureInfo englishCulture = new("en-US");

    private Event? eventModel;
    private bool isLoading = true;
    private bool isSubmitting = false;

    private string message = string.Empty;
    private string messageCss = "alert-info";
    private string dateValidationMessage = string.Empty;

    private string googleMapsSearchUrl = string.Empty;
    private string googleMapsEmbedUrl = string.Empty;

    private readonly List<string> categories = new()
    {
        "Conference",
        "Workshop",
        "Concert",
        "Sports",
        "Networking",
        "Festival",
        "Seminar",
        "Other"
    };

    private DateTime minimumEventDate => DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var existingEvent = await Db.Events.FirstOrDefaultAsync(e => e.Id == Id);

        if (existingEvent == null || string.IsNullOrWhiteSpace(userId) || existingEvent.CreatorId != userId)
        {
            eventModel = null;
            isLoading = false;
            return;
        }

        eventModel = existingEvent;
        eventModel.Date = DateTime.SpecifyKind(eventModel.Date, DateTimeKind.Utc).ToLocalTime();

        UpdateMapUrl();
        isLoading = false;
    }

    private void OnLocationChanged(ChangeEventArgs e)
    {
        if (eventModel == null)
            return;

        eventModel.Location = e.Value?.ToString() ?? string.Empty;
        UpdateMapUrl();
    }

    private void UpdateMapUrl()
    {
        var location = eventModel?.Location ?? string.Empty;
        var encodedLocation = Uri.EscapeDataString(location);

        googleMapsSearchUrl = $"https://www.google.com/maps/search/?api=1&query={encodedLocation}";
        googleMapsEmbedUrl = $"https://www.google.com/maps?q={encodedLocation}&output=embed";
    }

    private async Task HandleEditEvent()
    {
        if (eventModel == null)
            return;

        isSubmitting = true;
        message = string.Empty;
        messageCss = "alert-info";
        dateValidationMessage = string.Empty;

        try
        {
            if (eventModel.Date <= DateTime.Now)
            {
                dateValidationMessage = "Event date must be in the future.";
                return;
            }

            UpdateMapUrl();

            var localEventDate = DateTime.SpecifyKind(eventModel.Date, DateTimeKind.Local);
            eventModel.Date = localEventDate.ToUniversalTime();

            await Db.SaveChangesAsync();

            message = "Event updated successfully.";
            messageCss = "alert-success";

            await Task.Delay(600);
            NavigationManager.NavigateTo("/my-events");
        }
        catch (Exception ex)
        {
            message = ex.Message;
            messageCss = "alert-danger";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/my-events");
    }
}