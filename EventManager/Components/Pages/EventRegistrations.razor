@page "/events/{Id:int}/registrations"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "EventManager")]

@using System.Security.Claims
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Event Registrations</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <p>Loading registrations...</p>
    }
    else if (eventItem == null)
    {
        <div class="alert alert-warning">
            Event not found or access denied.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
            <div>
                <h1 class="mb-1">Registrations</h1>
                <p class="text-muted mb-0">@eventItem.Title</p>
            </div>

            <a class="btn btn-outline-secondary" href="/my-events">Back to My Events</a>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <strong>Category:</strong><br />
                        <span>@eventItem.Category</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Date:</strong><br />
                        <span>@eventItem.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Location:</strong><br />
                        <span>@eventItem.Location</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Registered:</strong><br />
                        <span>@registrations.Count / @eventItem.Capacity</span>
                    </div>
                </div>
            </div>
        </div>

        @if (!registrations.Any())
        {
            <div class="alert alert-info">
                No one has registered for this event yet.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Username</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Registered At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in registrations.Select((value, index) => new { value, index }))
                        {
                            <tr>
                                <td>@(item.index + 1)</td>
                                <td>@item.value.UserName</td>
                                <td>@item.value.FullName</td>
                                <td>@item.value.Email</td>
                                <td>@item.value.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? eventItem;
    private bool isLoading = true;

    private List<RegistrationViewModel> registrations = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        eventItem = await Db.Events.FirstOrDefaultAsync(e => e.Id == Id);

        if (eventItem == null || eventItem.CreatorId != userId)
        {
            eventItem = null;
            isLoading = false;
            return;
        }

        var eventRegistrations = await Db.Registrations
            .Where(r => r.EventId == Id)
            .OrderByDescending(r => r.RegisteredAt)
            .ToListAsync();

        foreach (var registration in eventRegistrations)
        {
            var registeredUser = await UserManager.FindByIdAsync(registration.UserId);

            if (registeredUser != null)
            {
                registrations.Add(new RegistrationViewModel
                {
                    UserName = registeredUser.UserName ?? "",
                    FullName = $"{registeredUser.FirstName} {registeredUser.LastName}".Trim(),
                    Email = registeredUser.Email ?? "",
                    RegisteredAt = registration.RegisteredAt
                });
            }
        }

        isLoading = false;
    }

    private class RegistrationViewModel
    {
        public string UserName { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public DateTime RegisteredAt { get; set; }
    }
}