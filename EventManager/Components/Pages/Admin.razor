@page "/admin"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ApplicationDbContext Db

<PageTitle>Admin Dashboard</PageTitle>

<div class="container py-4 admin-dashboard">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Admin Dashboard</h1>
            <p class="text-muted mb-0">Manage users, approvals, and platform activity.</p>
        </div>

        <div class="mt-3 mt-md-0 d-flex gap-2 flex-wrap">
            <a href="/admin/approvals" class="btn btn-primary">
                <i class="bi bi-person-check me-2"></i>Approvals
            </a>
            <a href="/admin/events" class="btn btn-outline-secondary">
                <i class="bi bi-calendar-event me-2"></i>Manage Events
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span>Loading dashboard data...</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card shadow-sm border-0 stat-card h-100">
                    <div class="card-body">
                        <div class="stat-icon bg-primary-subtle text-primary">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h6 class="text-muted mt-3 mb-1">Total Users</h6>
                        <h2 class="fw-bold mb-0">@totalUsers</h2>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card shadow-sm border-0 stat-card h-100">
                    <div class="card-body">
                        <div class="stat-icon bg-success-subtle text-success">
                            <i class="bi bi-person-badge-fill"></i>
                        </div>
                        <h6 class="text-muted mt-3 mb-1">Event Managers</h6>
                        <h2 class="fw-bold mb-0">@totalEventManagers</h2>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card shadow-sm border-0 stat-card h-100">
                    <div class="card-body">
                        <div class="stat-icon bg-warning-subtle text-warning">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                        <h6 class="text-muted mt-3 mb-1">Pending Requests</h6>
                        <h2 class="fw-bold mb-0">@pendingApprovals</h2>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card shadow-sm border-0 stat-card h-100">
                    <div class="card-body">
                        <div class="stat-icon bg-info-subtle text-info">
                            <i class="bi bi-calendar2-event-fill"></i>
                        </div>
                        <h6 class="text-muted mt-3 mb-1">Total Events</h6>
                        <h2 class="fw-bold mb-0">@totalEvents</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-xl-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                        <h4 class="fw-semibold mb-1">Pending Event Manager Requests</h4>
                        <p class="text-muted mb-0">Latest users waiting for admin approval.</p>
                    </div>
                    <div class="card-body p-4">
                        @if (recentPendingUsers.Count == 0)
                        {
                            <div class="alert alert-info mb-0">
                                There are currently no pending requests.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Requested Role</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in recentPendingUsers)
                                        {
                                            <tr>
                                                <td>@user.FirstName @user.LastName</td>
                                                <td>@user.Email</td>
                                                <td>@user.RequestedRole</td>
                                                <td>
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="mt-3">
                                <a href="/admin/approvals" class="btn btn-sm btn-outline-primary">
                                    Go to approvals
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                        <h4 class="fw-semibold mb-1">Quick Actions</h4>
                        <p class="text-muted mb-0">Common admin tasks.</p>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-grid gap-3">

                            <a href="/admin/approvals" class="btn btn-outline-primary btn-lg text-start">
                                <i class="bi bi-person-check me-2"></i>
                                Review manager approvals
                            </a>

                            <a href="/admin/users" class="btn btn-outline-secondary btn-lg text-start">
                                <i class="bi bi-people me-2"></i>
                                View all users
                            </a>

                            <a href="/admin/events" class="btn btn-outline-secondary btn-lg text-start">
                                <i class="bi bi-calendar3 me-2"></i>
                                Manage all events
                            </a>

                        </div>

                        <hr class="my-4" />

                        <div class="small text-muted">
                            <div class="mb-2">
                                <strong>Admin email:</strong> admin@eventmanager.com
                            </div>
                            <div>
                                This page is visible only to users in the <strong>Admin</strong> role.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .admin-dashboard .stat-card {
        border-radius: 1rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .admin-dashboard .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.08);
        }

    .admin-dashboard .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .admin-dashboard .card {
        border-radius: 1rem;
    }
</style>

@code {
    private bool isLoading = true;

    private int totalUsers;
    private int totalEventManagers;
    private int pendingApprovals;
    private int totalEvents;

    private List<ApplicationUser> recentPendingUsers = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;

        totalUsers = await UserManager.Users.CountAsync();

        pendingApprovals = await UserManager.Users
            .CountAsync(u => u.RequestedRole == "EventManager" && !u.IsApproved);

        totalEvents = await Db.Events.CountAsync();

        totalEventManagers = 0;
        var users = await UserManager.Users.ToListAsync();

        foreach (var user in users)
        {
            if (await UserManager.IsInRoleAsync(user, "EventManager"))
            {
                totalEventManagers++;
            }
        }

        recentPendingUsers = await UserManager.Users
            .Where(u => u.RequestedRole == "EventManager" && !u.IsApproved)
            .OrderBy(u => u.FirstName)
            .ThenBy(u => u.LastName)
            .Take(5)
            .ToListAsync();

        isLoading = false;
    }
}