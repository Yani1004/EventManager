@page "/events"
@rendermode InteractiveServer

@using EventManager.Models
@using EventManager.Services.Interfaces
@using Radzen
@using Radzen.Blazor

@inject IEventService EventService
@inject NavigationManager NavigationManager

<PageTitle>Events</PageTitle>

<div class="events-page">
    <RadzenStack Gap="1.5rem" class="page-stack">

        <RadzenCard class="page-header-card">
            <RadzenStack Orientation="Orientation.Horizontal"
                         JustifyContent="JustifyContent.SpaceBetween"
                         AlignItems="AlignItems.Center"
                         Wrap="FlexWrap.Wrap"
                         Gap="1rem">
                <RadzenStack Gap="0.35rem">
                    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="page-title">
                        Upcoming Events
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body1" class="page-subtitle">
                        Browse events and refine the list with sorting and filters.
                    </RadzenText>
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.End"
                             Wrap="FlexWrap.Wrap"
                             Gap="0.75rem"
                             class="header-actions">
                    <RadzenStack Gap="0.35rem" class="sort-box">
                        <RadzenText TextStyle="TextStyle.Body2" class="field-label">Sort By</RadzenText>
                        <RadzenDropDown @bind-Value="selectedSort"
                                        Data="@sortOptions"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        Style="width: 100%;"
                                        class="radzen-input" />
                    </RadzenStack>

                    <RadzenButton Text="@(showFilters ? "Hide Filters" : "Filters")"
                                  Icon="filter_alt"
                                  Size="ButtonSize.Large"
                                  Variant="Variant.Outlined"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  class="filters-toggle-button"
                                  Click="@ToggleFilters" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @if (showFilters)
        {
            <RadzenCard class="filters-card">
                <RadzenStack Gap="1.25rem">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 AlignItems="AlignItems.Center"
                                 Wrap="FlexWrap.Wrap"
                                 Gap="0.75rem">
                        <RadzenStack Gap="0.2rem">
                            <RadzenText TextStyle="TextStyle.H6" class="section-title">
                                Filter Events
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" class="section-subtitle">
                                Narrow the list to find the events that fit you best.
                            </RadzenText>
                        </RadzenStack>

                        <RadzenButton Text="Clear All"
                                      Icon="restart_alt"
                                      Variant="Variant.Outlined"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@ClearFilters" />
                    </RadzenStack>

                    <RadzenRow Gap="1rem" RowGap="1rem">
                        <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                            <RadzenStack Gap="0.35rem">
                                <RadzenText TextStyle="TextStyle.Body2" class="field-label">Category</RadzenText>
                                <RadzenDropDown @bind-Value="selectedCategory"
                                                Data="@categories"
                                                AllowClear="true"
                                                Placeholder="All Categories"
                                                Style="width: 100%;"
                                                class="radzen-input" />
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMD="6" SizeXL="3">
                            <RadzenStack Gap="0.35rem">
                                <RadzenText TextStyle="TextStyle.Body2" class="field-label">City / Location</RadzenText>
                                <RadzenTextBox @bind-Value="locationFilter"
                                               Placeholder="Search by location"
                                               Style="width: 100%;"
                                               class="radzen-input" />
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMD="6" SizeXL="2">
                            <RadzenStack Gap="0.35rem">
                                <RadzenText TextStyle="TextStyle.Body2" class="field-label">Min Price</RadzenText>
                                <RadzenNumeric @bind-Value="minPrice"
                                               TValue="decimal?"
                                               Placeholder="0.00"
                                               Style="width: 100%;"
                                               class="radzen-input" />
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMD="6" SizeXL="2">
                            <RadzenStack Gap="0.35rem">
                                <RadzenText TextStyle="TextStyle.Body2" class="field-label">Max Price</RadzenText>
                                <RadzenNumeric @bind-Value="maxPrice"
                                               TValue="decimal?"
                                               Placeholder="0.00"
                                               Style="width: 100%;"
                                               class="radzen-input" />
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeXL="2">
                            <RadzenStack Gap="0.35rem" class="free-only-box">
                                <RadzenText TextStyle="TextStyle.Body2" class="field-label">Quick Option</RadzenText>
                                <RadzenStack Orientation="Orientation.Horizontal"
                                             AlignItems="AlignItems.Center"
                                             Gap="0.65rem"
                                             class="free-switch-row">
                                    <RadzenSwitch @bind-Value="freeOnly" />
                                    <RadzenText TextStyle="TextStyle.Body2" class="switch-label">
                                        Free events only
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenCard>
        }

        @if (HasActiveFilters)
        {
            <RadzenStack Orientation="Orientation.Horizontal"
                         Wrap="FlexWrap.Wrap"
                         Gap="0.65rem"
                         class="active-filters">
                @if (!string.IsNullOrWhiteSpace(selectedCategory))
                {
                    <div class="filter-chip">
                        <span>Category: @selectedCategory</span>
                        <RadzenButton Icon="close"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Text"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      class="chip-button"
                                      Click="@ClearCategory" />
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(locationFilter))
                {
                    <div class="filter-chip">
                        <span>Location: @locationFilter</span>
                        <RadzenButton Icon="close"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Text"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      class="chip-button"
                                      Click="@ClearLocation" />
                    </div>
                }

                @if (minPrice.HasValue)
                {
                    <div class="filter-chip">
                        <span>Min: @minPrice.Value.ToString("F2") lv.</span>
                        <RadzenButton Icon="close"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Text"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      class="chip-button"
                                      Click="@ClearMinPrice" />
                    </div>
                }

                @if (maxPrice.HasValue)
                {
                    <div class="filter-chip">
                        <span>Max: @maxPrice.Value.ToString("F2") lv.</span>
                        <RadzenButton Icon="close"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Text"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      class="chip-button"
                                      Click="@ClearMaxPrice" />
                    </div>
                }

                @if (freeOnly)
                {
                    <div class="filter-chip">
                        <span>Free only</span>
                        <RadzenButton Icon="close"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Text"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      class="chip-button"
                                      Click="@ClearFreeOnly" />
                    </div>
                }
            </RadzenStack>
        }

        @if (events == null)
        {
            <RadzenCard class="state-card">
                <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="state-stack">
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.Body1">Loading events...</RadzenText>
                </RadzenStack>
            </RadzenCard>
        }
        else
        {
            <RadzenCard class="results-card">
                <RadzenStack Orientation="Orientation.Horizontal"
                             JustifyContent="JustifyContent.SpaceBetween"
                             AlignItems="AlignItems.Center"
                             Wrap="FlexWrap.Wrap"
                             Gap="0.75rem">
                    <RadzenText TextStyle="TextStyle.Body1" class="results-count">
                        @filteredAndSortedEvents.Count() event(s) found
                    </RadzenText>

                    <RadzenText TextStyle="TextStyle.Body2" class="results-hint">
                        Showing active upcoming events
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>

            @if (!filteredAndSortedEvents.Any())
            {
                <RadzenCard class="empty-card">
                    <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="state-stack">
                        <div class="empty-icon-wrap">
                            <RadzenIcon Icon="search_off" class="empty-icon" />
                        </div>

                        <RadzenText TextStyle="TextStyle.H5" class="empty-title">
                            No matching events
                        </RadzenText>

                        <RadzenText TextStyle="TextStyle.Body1" class="empty-text">
                            Try changing the selected filters or clearing them to see more results.
                        </RadzenText>

                        <RadzenButton Text="Clear Filters"
                                      Icon="restart_alt"
                                      Variant="Variant.Outlined"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@ClearFilters" />
                    </RadzenStack>
                </RadzenCard>
            }
            else
            {
                <RadzenRow Gap="1.5rem" RowGap="1.5rem" class="cards-row">
                    @foreach (var ev in filteredAndSortedEvents)
                    {
                        <RadzenColumn Size="12" SizeMD="6" SizeXL="4">
                            <RadzenCard class="event-card">
                                <RadzenStack Gap="0" class="event-card-stack">
                                    <div class="image-wrap">
                                        <img src="@(string.IsNullOrWhiteSpace(ev.ImageUrl) ? "https://via.placeholder.com/400x220?text=No+Image" : ev.ImageUrl)"
                                             alt="@ev.Title"
                                             class="event-image" />

                                        <RadzenBadge Text="@ev.Category"
                                                     class="category-badge" />
                                    </div>

                                    <RadzenStack Gap="0.95rem" class="event-content">
                                        <RadzenStack Gap="0.35rem">
                                            <RadzenText TextStyle="TextStyle.H6" class="event-title">
                                                @ev.Title
                                            </RadzenText>

                                            <RadzenText TextStyle="TextStyle.Body2" class="description-text">
                                                @(string.IsNullOrWhiteSpace(ev.Description)
                                                    ? "No description available."
                                                    : (ev.Description.Length > 100
                                                        ? ev.Description.Substring(0, 100) + "..."
                                                        : ev.Description))
                                            </RadzenText>
                                        </RadzenStack>

                                        <RadzenStack Gap="0.75rem" class="details-stack">
                                            <RadzenStack Orientation="Orientation.Horizontal"
                                                         AlignItems="AlignItems.Start"
                                                         Gap="0.65rem">
                                                <div class="detail-icon-wrap">
                                                    <RadzenIcon Icon="calendar_month" class="detail-icon" />
                                                </div>
                                                <RadzenStack Gap="0.15rem">
                                                    <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Date</RadzenText>
                                                    <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                        @ev.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                    </RadzenText>
                                                </RadzenStack>
                                            </RadzenStack>

                                            <RadzenStack Orientation="Orientation.Horizontal"
                                                         AlignItems="AlignItems.Start"
                                                         Gap="0.65rem">
                                                <div class="detail-icon-wrap">
                                                    <RadzenIcon Icon="place" class="detail-icon" />
                                                </div>
                                                <RadzenStack Gap="0.15rem">
                                                    <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Location</RadzenText>
                                                    <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                        @ev.Location
                                                    </RadzenText>
                                                </RadzenStack>
                                            </RadzenStack>

                                            <RadzenStack Orientation="Orientation.Horizontal"
                                                         AlignItems="AlignItems.Start"
                                                         Gap="0.65rem">
                                                <div class="detail-icon-wrap">
                                                    <RadzenIcon Icon="payments" class="detail-icon" />
                                                </div>
                                                <RadzenStack Gap="0.15rem">
                                                    <RadzenText TextStyle="TextStyle.Caption" class="detail-label">Price</RadzenText>
                                                    <RadzenText TextStyle="TextStyle.Body2" class="detail-value">
                                                        @(ev.Price == 0 ? "Free" : $"{ev.Price:F2} lv.")
                                                    </RadzenText>
                                                </RadzenStack>
                                            </RadzenStack>
                                        </RadzenStack>

                                        <RadzenButton Text="View More"
                                                      Icon="arrow_forward"
                                                      Variant="Variant.Outlined"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      class="view-button"
                                                      Click='@(() => NavigationManager.NavigateTo($"/events/{ev.Id}"))' />
                                    </RadzenStack>
                                </RadzenStack>
                            </RadzenCard>
                        </RadzenColumn>
                    }
                </RadzenRow>
            }
        }
    </RadzenStack>
</div>

<style>
    .events-page {
        padding: 1.5rem;
    }

    .page-stack {
        max-width: 88rem;
        margin: 0 auto;
    }

    .page-header-card,
    .filters-card,
    .results-card,
    .state-card,
    .empty-card,
    .event-card {
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 1.125rem 2.8125rem rgba(15, 23, 42, 0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
    }

    .page-header-card {
        padding: 0.5rem;
    }

    .page-title {
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .page-subtitle,
    .section-subtitle,
    .results-hint,
    .description-text {
        color: #64748b;
    }

    .header-actions {
        width: auto;
    }

    .sort-box {
        min-width: 16rem;
    }

    .filters-toggle-button {
        min-width: 9rem;
    }

    .field-label,
    .detail-label {
        color: #64748b;
        font-weight: 600;
    }

    .filters-card,
    .results-card,
    .state-card,
    .empty-card {
        padding: 1.25rem;
    }

    .section-title {
        font-weight: 700;
        color: #0f172a;
    }

    .free-only-box {
        height: 100%;
    }

    .free-switch-row {
        min-height: 2.875rem;
        padding: 0.55rem 0.8rem;
        border-radius: 1rem;
        background: #f8fafc;
        border: 0.0625rem solid #e2e8f0;
    }

    .switch-label {
        color: #0f172a;
        font-weight: 500;
    }

    .active-filters {
        margin-top: -0.25rem;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: #f8fafc;
        border: 0.0625rem solid #e2e8f0;
        border-radius: 999rem;
        padding: 0.3rem 0.45rem 0.3rem 0.8rem;
        color: #334155;
        font-size: 0.92rem;
    }

    .chip-button {
        min-width: auto !important;
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 999rem;
    }

    .results-count {
        color: #334155;
        font-weight: 700;
    }

    .state-stack {
        padding: 1rem 0;
    }

    .empty-icon-wrap {
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.10);
    }

    .empty-icon {
        font-size: 2rem;
        color: #2563eb;
    }

    .empty-title {
        font-weight: 700;
        color: #0f172a;
    }

    .empty-text {
        color: #64748b;
        text-align: center;
        max-width: 32rem;
    }

    .cards-row {
        margin: 0;
    }

    .event-card {
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        height: 100%;
    }

        .event-card:hover {
            transform: translateY(-0.3rem);
            box-shadow: 0 1.5rem 3rem rgba(15, 23, 42, 0.13);
        }

    .event-card-stack {
        height: 100%;
    }

    .image-wrap {
        position: relative;
    }

    .event-image {
        width: 100%;
        height: 14rem;
        object-fit: cover;
        display: block;
    }

    .category-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        border-radius: 999rem;
        padding: 0.4rem 0.8rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.94) !important;
        color: #0f172a !important;
        box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.12);
    }

    .event-content {
        padding: 1.25rem;
        flex: 1;
        justify-content: space-between;
        min-height: 18rem;
    }

    .event-title {
        font-weight: 700;
        color: #0f172a;
        line-height: 1.3;
    }

    .details-stack {
        padding-top: 0.15rem;
    }

    .detail-icon-wrap {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 0.85rem;
        background: rgba(37, 99, 235, 0.10);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .detail-icon {
        color: #2563eb;
        font-size: 1.1rem;
    }

    .detail-value {
        color: #0f172a;
        font-weight: 500;
        word-break: break-word;
    }

    .view-button {
        margin-top: auto;
        width: 100%;
        justify-content: center;
    }

    @@media (max-width: 75rem) {
        .events-page {
            padding: 1rem;
        }

        .page-stack {
            max-width: 100%;
        }
    }
</style>

@code {
    private List<Event>? events;

    private bool showFilters = false;

    private string selectedSort = "date_asc";
    private string selectedCategory = string.Empty;
    private string locationFilter = string.Empty;
    private decimal? minPrice;
    private decimal? maxPrice;
    private bool freeOnly = false;

    private readonly List<string> categories = new()
    {
        "Conference",
        "Workshop",
        "Concert",
        "Sports",
        "Networking",
        "Festival",
        "Seminar",
        "Other"
    };

    private readonly List<SortOption> sortOptions = new()
    {
        new() { Text = "Date: Soonest First", Value = "date_asc" },
        new() { Text = "Date: Latest First", Value = "date_desc" },
        new() { Text = "Price: Low to High", Value = "price_asc" },
        new() { Text = "Price: High to Low", Value = "price_desc" }
    };

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(selectedCategory) ||
        !string.IsNullOrWhiteSpace(locationFilter) ||
        minPrice.HasValue ||
        maxPrice.HasValue ||
        freeOnly;

    private IEnumerable<Event> filteredAndSortedEvents
    {
        get
        {
            IEnumerable<Event> query = events ?? Enumerable.Empty<Event>();

            if (!string.IsNullOrWhiteSpace(selectedCategory))
            {
                query = query.Where(e => e.Category == selectedCategory);
            }

            if (!string.IsNullOrWhiteSpace(locationFilter))
            {
                query = query.Where(e =>
                    !string.IsNullOrWhiteSpace(e.Location) &&
                    e.Location.Contains(locationFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (freeOnly)
            {
                query = query.Where(e => e.Price == 0);
            }
            else
            {
                if (minPrice.HasValue)
                {
                    query = query.Where(e => e.Price >= minPrice.Value);
                }

                if (maxPrice.HasValue)
                {
                    query = query.Where(e => e.Price <= maxPrice.Value);
                }
            }

            query = selectedSort switch
            {
                "date_desc" => query.OrderByDescending(e => e.Date),
                "price_asc" => query.OrderBy(e => e.Price).ThenBy(e => e.Date),
                "price_desc" => query.OrderByDescending(e => e.Price).ThenBy(e => e.Date),
                _ => query.OrderBy(e => e.Date)
            };

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetActiveEventsAsync();
    }

    private void ToggleFilters()
    {
        showFilters = !showFilters;
    }

    private void ClearFilters()
    {
        selectedCategory = string.Empty;
        locationFilter = string.Empty;
        minPrice = null;
        maxPrice = null;
        freeOnly = false;
        selectedSort = "date_asc";
    }

    private void ClearCategory()
    {
        selectedCategory = string.Empty;
    }

    private void ClearLocation()
    {
        locationFilter = string.Empty;
    }

    private void ClearMinPrice()
    {
        minPrice = null;
    }

    private void ClearMaxPrice()
    {
        maxPrice = null;
    }

    private void ClearFreeOnly()
    {
        freeOnly = false;
    }

    private class SortOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}