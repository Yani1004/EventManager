@page "/events/{Id:int}"
@rendermode InteractiveServer

@using System.Security.Claims
@using EventManager.Data
@using EventManager.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext Db
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Event Details</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <p>Loading event...</p>
    }
    else if (eventItem == null)
    {
        <div class="alert alert-warning">
            Event not found.
        </div>
    }
    else
    {
        <div class="card shadow-lg border-0">
            <img src="@(string.IsNullOrWhiteSpace(eventItem.ImageUrl) ? "https://via.placeholder.com/900x400?text=No+Image" : eventItem.ImageUrl)"
                 class="card-img-top details-image"
                 alt="@eventItem.Title" />

            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <h1 class="mb-0">@eventItem.Title</h1>
                    <span class="badge bg-light text-dark details-category-badge">@eventItem.Category</span>
                </div>

                <p class="mb-2"><strong>Date:</strong> @eventItem.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                <p class="mb-2"><strong>Location:</strong> @eventItem.Location</p>
                <p class="mb-2"><strong>Category:</strong> @eventItem.Category</p>
                <p class="mb-2"><strong>Capacity:</strong> @eventItem.Capacity</p>
                <p class="mb-2"><strong>Registered:</strong> @registeredCount / @eventItem.Capacity</p>
                <p class="mb-3"><strong>Price:</strong> @(eventItem.Price == 0 ? "Free" : $"{eventItem.Price:F2} lv.")</p>

                <h5>Description</h5>
                <p>@(string.IsNullOrWhiteSpace(eventItem.Description) ? "No description available." : eventItem.Description)</p>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert @messageCss mt-3">
                        @message
                    </div>
                }

                <div class="mt-3 d-flex gap-2 flex-wrap">
                    @if (canRegister && !isAlreadyRegistered)
                    {
                        <button class="btn btn-primary"
                                @onclick="RegisterForEvent"
                                disabled="@isRegistering">
                            @(isRegistering ? "Registering..." : "Register")
                        </button>
                    }

                    @if (canRegister && isAlreadyRegistered)
                    {
                        <button class="btn btn-outline-danger"
                                @onclick="CancelRegistrationFromDetails">
                            Cancel Registration
                        </button>
                    }

                    @if (canManageEvent)
                    {
                        <a class="btn btn-warning" href="/events/edit/@eventItem.Id">Edit</a>
                        <a class="btn btn-danger" href="/events/delete/@eventItem.Id">Delete</a>
                    }

                    <button class="btn btn-secondary" @onclick="GoBack">
                        Back to Events
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .details-image {
        height: 400px;
        object-fit: cover;
    }

    .details-category-badge {
        border-radius: 999px;
        font-weight: 500;
        padding: 0.5rem 0.8rem;
        white-space: nowrap;
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? eventItem;
    private bool isLoading = true;
    private bool isRegistering = false;
    private bool canRegister = false;
    private bool canManageEvent = false;
    private int registeredCount = 0;
    private bool isAlreadyRegistered = false;
    private int? currentRegistrationId = null;

    private string message = string.Empty;
    private string messageCss = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadEventData();
    }

    private async Task LoadEventData()
    {
        eventItem = await Db.Events.FirstOrDefaultAsync(e => e.Id == Id);

        if (eventItem != null)
        {
            registeredCount = await Db.Registrations.CountAsync(r => r.EventId == eventItem.Id);

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                if (user.IsInRole("Attendee"))
                {
                    canRegister = true;

                    var existingRegistration = await Db.Registrations
                        .FirstOrDefaultAsync(r => r.EventId == eventItem.Id && r.UserId == userId);

                    if (existingRegistration != null)
                    {
                        isAlreadyRegistered = true;
                        currentRegistrationId = existingRegistration.Id;
                    }
                }

                if (user.IsInRole("EventManager") && userId == eventItem.CreatorId)
                {
                    canManageEvent = true;
                }
            }
        }

        isLoading = false;
    }

    private async Task RegisterForEvent()
    {
        if (eventItem == null)
            return;

        isRegistering = true;
        message = string.Empty;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true)
            {
                message = "You must be logged in to register.";
                messageCss = "alert-danger";
                return;
            }

            if (!user.IsInRole("Attendee"))
            {
                message = "Only attendees can register for events.";
                messageCss = "alert-warning";
                return;
            }

            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                message = "Could not identify the current user.";
                messageCss = "alert-danger";
                return;
            }

            var alreadyRegistered = await Db.Registrations
                .AnyAsync(r => r.EventId == eventItem.Id && r.UserId == userId);

            if (alreadyRegistered)
            {
                message = "You are already registered for this event.";
                messageCss = "alert-warning";
                return;
            }

            var currentCount = await Db.Registrations
                .CountAsync(r => r.EventId == eventItem.Id);

            if (currentCount >= eventItem.Capacity)
            {
                message = "This event is already full.";
                messageCss = "alert-danger";
                return;
            }

            var registration = new Registration
            {
                EventId = eventItem.Id,
                UserId = userId,
                RegisteredAt = DateTime.UtcNow
            };

            Db.Registrations.Add(registration);
            await Db.SaveChangesAsync();

            registeredCount++;
            isAlreadyRegistered = true;
            currentRegistrationId = registration.Id;

            message = "You successfully registered for the event.";
            messageCss = "alert-success";
        }
        catch
        {
            message = "Something went wrong while registering.";
            messageCss = "alert-danger";
        }
        finally
        {
            isRegistering = false;
        }
    }

    private async Task CancelRegistrationFromDetails()
    {
        if (currentRegistrationId == null || eventItem == null)
            return;

        var registration = await Db.Registrations
            .FirstOrDefaultAsync(r => r.Id == currentRegistrationId.Value);

        if (registration == null)
        {
            message = "Registration not found.";
            messageCss = "alert-danger";
            return;
        }

        Db.Registrations.Remove(registration);
        await Db.SaveChangesAsync();

        isAlreadyRegistered = false;
        currentRegistrationId = null;
        registeredCount--;

        message = "Registration cancelled successfully.";
        messageCss = "alert-success";
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/events");
    }
}