@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen
@using Radzen.Blazor
@using Microsoft.JSInterop

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="app-sidebar @(isCollapsed ? "collapsed" : "")">
    <RadzenCard class="sidebar-card">
        <RadzenStack Orientation="Orientation.Vertical" Gap="0" class="sidebar-stack">

            @if (!isCollapsed)
            {
                <div class="sidebar-header">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 Gap="0.75rem"
                                 class="w-100">

                        <RadzenStack Orientation="Orientation.Horizontal"
                                     AlignItems="AlignItems.Center"
                                     Gap="0.9rem"
                                     class="brand-row">
                            <div class="brand-badge">
                                <RadzenIcon Icon="event" class="brand-icon" />
                            </div>

                            <div class="brand-copy">
                                <div class="brand-title">EventManager</div>
                                <div class="brand-subtitle">Manage events beautifully</div>
                            </div>
                        </RadzenStack>

                        <RadzenButton Icon="menu"
                                      Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Medium"
                                      Click="@ToggleSidebar"
                                      class="sidebar-toggle" />
                    </RadzenStack>
                </div>

                <RadzenDivider class="menu-divider" />
            }
            else
            {
                <div class="sidebar-header-collapsed">
                    <div class="collapsed-inner">
                        <RadzenButton Icon="menu"
                                      Variant="Variant.Flat"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Medium"
                                      Click="@ToggleSidebar"
                                      class="sidebar-toggle collapsed-toggle" />
                    </div>
                </div>
            }

            <div class="sidebar-nav @(isCollapsed ? "sidebar-nav-collapsed" : "")">
                @if (!isCollapsed)
                {
                    <RadzenPanelMenu ShowArrow="false" Multiple="true" class="menu-full">
                        <RadzenPanelMenuItem Text="Home" Icon="home" Path="" />
                        <RadzenPanelMenuItem Text="Events" Icon="calendar_month" Path="events" />

                        <AuthorizeView>
                            <NotAuthorized>
                                <RadzenPanelMenuItem Text="Register" Icon="person_add" Path="register" />
                            </NotAuthorized>
                        </AuthorizeView>

                        <AuthorizeView Roles="Attendee">
                            <Authorized>
                                <RadzenPanelMenuItem Text="My Registrations" Icon="fact_check" Path="my-registrations" />
                            </Authorized>
                        </AuthorizeView>

                        <AuthorizeView Roles="EventManager">
                            <Authorized>
                                <RadzenPanelMenuItem Text="Create Event" Icon="add_circle" Path="events/create" />
                                <RadzenPanelMenuItem Text="My Events" Icon="folder_open" Path="my-events" />
                            </Authorized>
                        </AuthorizeView>

                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                <RadzenPanelMenuItem Text="Admin Panel" Icon="admin_panel_settings" Path="admin" />
                                <RadzenPanelMenuItem Text="Approvals" Icon="how_to_reg" Path="admin/approvals" />
                                <RadzenPanelMenuItem Text="Users" Icon="groups" Path="admin/users" />
                                <RadzenPanelMenuItem Text="Manage Events" Icon="event_available" Path="admin/events" />
                            </Authorized>
                        </AuthorizeView>
                    </RadzenPanelMenu>
                }
                else
                {
                    <div class="collapsed-inner">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.85rem" class="menu-collapsed">
                            <RadzenButton Icon="home"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Light"
                                          class="collapsed-nav-btn"
                                          Click='@(() => NavigateTo(""))' />

                            <RadzenButton Icon="calendar_month"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Light"
                                          class="collapsed-nav-btn"
                                          Click='@(() => NavigateTo("events"))' />

                            <AuthorizeView>
                                <NotAuthorized>
                                    <RadzenButton Icon="person_add"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("register"))' />
                                </NotAuthorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="Attendee">
                                <Authorized>
                                    <RadzenButton Icon="fact_check"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("my-registrations"))' />
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="EventManager">
                                <Authorized>
                                    <RadzenButton Icon="add_circle"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("events/create"))' />

                                    <RadzenButton Icon="folder_open"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("my-events"))' />
                                </Authorized>
                            </AuthorizeView>

                            <AuthorizeView Roles="Admin">
                                <Authorized>
                                    <RadzenButton Icon="admin_panel_settings"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("admin"))' />

                                    <RadzenButton Icon="how_to_reg"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("admin/approvals"))' />

                                    <RadzenButton Icon="groups"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("admin/users"))' />

                                    <RadzenButton Icon="event_available"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Light"
                                                  class="collapsed-nav-btn"
                                                  Click='@(() => NavigateTo("admin/events"))' />
                                </Authorized>
                            </AuthorizeView>
                        </RadzenStack>
                    </div>
                }
            </div>

            <div class="sidebar-fill"></div>

            <AuthorizeView>
                <Authorized>
                    @if (!isCollapsed)
                    {
                        <RadzenDivider class="menu-divider" />

                        <div class="profile-block" @onclick='@(() => NavigateTo("profile"))'>
                            <RadzenStack Orientation="Orientation.Horizontal"
                                         AlignItems="AlignItems.Center"
                                         Gap="0.85rem">
                                <RadzenAvatar Text="@GetInitials(displayName)" class="profile-avatar" />

                                <div class="profile-copy">
                                    <div class="profile-name">@displayName</div>
                                    <RadzenBadge Text="@userRole"
                                                 Variant="Variant.Flat"
                                                 Shade="Shade.Light"
                                                 class="profile-role" />
                                </div>
                            </RadzenStack>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>

        </RadzenStack>
    </RadzenCard>
</div>

<style>
    .app-sidebar {
        width: 320px;
        min-width: 320px;
        height: 100vh;
        padding: 1rem;
        background: #f5f7fb;
        transition: width 0.25s ease, min-width 0.25s ease;
    }

    .app-sidebar.collapsed {
        width: 110px;
        min-width: 110px;
    }

    .sidebar-card {
        height: calc(100vh - 2rem);
        border-radius: 30px;
        border: 1px solid #e8edf5;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .sidebar-stack {
        height: 100%;
    }

    .sidebar-header {
        padding: 1.2rem 1.1rem 1rem 1.1rem;
    }

    .sidebar-header-collapsed {
        padding: 1.15rem 0 0.55rem 0;
    }

    .collapsed-inner {
        width: 56px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .brand-row {
        min-width: 0;
        flex: 1;
    }

    .brand-badge {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #5b6df9 0%, #6f86ff 100%);
        box-shadow: 0 10px 24px rgba(91, 109, 249, 0.28);
        flex-shrink: 0;
    }

    .brand-icon {
        color: white;
        font-size: 24px;
    }

    .brand-copy {
        min-width: 0;
        overflow: hidden;
    }

    .brand-title {
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1.1;
        color: #122033;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .brand-subtitle {
        margin-top: 0.2rem;
        font-size: 0.82rem;
        color: #64748b;
        line-height: 1.35;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sidebar-toggle {
        width: 56px;
        height: 56px;
        border-radius: 18px !important;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .collapsed-toggle {
        margin: 0;
    }

    .menu-divider {
        margin: 0 !important;
    }

    .sidebar-nav {
        padding: 1rem 0.8rem;
    }

    .sidebar-nav-collapsed {
        padding: 0.35rem 0 1rem 0;
    }

    .menu-full {
        border: none !important;
        background: transparent !important;
    }

    .menu-full .rz-navigation-item-wrapper {
        margin-bottom: 0.45rem;
        border-radius: 18px;
        overflow: hidden;
    }

    .menu-full .rz-navigation-item-link {
        min-height: 54px;
        border-radius: 18px;
        color: #24364a;
        font-weight: 600;
        font-size: 1rem;
        padding-left: 1rem;
        transition: all 0.2s ease;
    }

    .menu-full .rz-navigation-item-link:hover {
        background: #edf2ff;
        color: #3158f5;
    }

    .menu-full .rz-state-active > .rz-navigation-item-link,
    .menu-full .rz-navigation-item-link.rz-state-active {
        background: linear-gradient(90deg, #eceeff 0%, #e8edff 100%);
        color: #4254d8;
    }

    .menu-collapsed {
        align-items: center;
        padding-top: 0;
        width: 56px;
    }

    .collapsed-nav-btn {
        width: 56px;
        height: 56px;
        border-radius: 18px !important;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
    }

    .sidebar-fill {
        flex: 1;
    }

    .profile-block {
        padding: 1rem;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .profile-block:hover {
        background: rgba(91, 109, 249, 0.06);
    }

    .profile-avatar {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #7c66ff 0%, #5b6df9 100%) !important;
        color: white !important;
        font-weight: 700;
        flex-shrink: 0;
        border-radius: 14px !important;
    }

    .profile-copy {
        min-width: 0;
    }

    .profile-name {
        font-size: 1rem;
        font-weight: 700;
        color: #162334;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0.35rem;
    }

    .profile-role {
        border-radius: 999px;
        font-weight: 600;
    }

    .w-100 {
        width: 100%;
    }
</style>

@code {
    private bool isCollapsed = false;
    private string displayName = "";
    private string userRole = "";

    private async Task ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
        await SetBodySidebarState();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            displayName = user.Identity.Name ?? "User";

            if (user.IsInRole("Admin"))
                userRole = "Admin";
            else if (user.IsInRole("EventManager"))
                userRole = "EventManager";
            else if (user.IsInRole("Attendee"))
                userRole = "Attendee";
            else
                userRole = "User";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SetBodySidebarState();
        }
    }

    private async Task SetBodySidebarState()
    {
        await JS.InvokeVoidAsync("eval", isCollapsed
            ? "document.body.classList.add('sidebar-collapsed')"
            : "document.body.classList.remove('sidebar-collapsed')");
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpper();

        return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[1][0])}";
    }
}