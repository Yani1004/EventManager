@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager

<div class="sidebar @(isCollapsed ? "collapsed" : "")">
    <div class="top-row navbar navbar-dark px-3">
        <div class="d-flex align-items-center justify-content-between w-100">
            @if (!isCollapsed)
            {
                <a class="navbar-brand m-0" href="">EventManager</a>
            }
            else
            {
                <a class="navbar-brand m-0" href="">EM</a>
            }

            <button class="toggle-btn" @onclick="ToggleSidebar" type="button">
                <span class="bi bi-list"></span>
            </button>
        </div>
    </div>

    <div class="nav-scrollable">
        <nav class="nav flex-column">

            <!-- Home: visible to guests, attendees, and event managers -->
            <AuthorizeView Roles="Attendee,EventManager">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            <span class="bi bi-house-door-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Home</span>
                            }
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            <span class="bi bi-house-door-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Home</span>
                            }
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <!-- Public Events: visible to guests, attendees, and event managers -->
            <AuthorizeView Roles="Attendee,EventManager">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="events">
                            <span class="bi bi-calendar-event-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Events</span>
                            }
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="events">
                            <span class="bi bi-calendar-event-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Events</span>
                            }
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <!-- Guest-only links -->
            <AuthorizeView>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="register">
                            <span class="bi bi-person-plus-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Register</span>
                            }
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="login">
                            <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Login</span>
                            }
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <!-- Attendee-only -->
            <AuthorizeView Roles="Attendee">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="my-registrations">
                            <span class="bi bi-journal-check" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">My Registrations</span>
                            }
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <!-- EventManager-only -->
            <AuthorizeView Roles="EventManager">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="events/create">
                            <span class="bi bi-plus-circle" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Create Event</span>
                            }
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="my-events">
                            <span class="bi bi-folder2-open" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">My Events</span>
                            }
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <!-- Admin-only -->
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin">
                            <span class="bi bi-shield-lock-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Admin Panel</span>
                            }
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/approvals">
                            <span class="bi bi-person-check-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Approvals</span>
                            }
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/users">
                            <span class="bi bi-people-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Users</span>
                            }
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/events">
                            <span class="bi bi-calendar2-check-fill" aria-hidden="true"></span>
                            @if (!isCollapsed)
                            {
                                <span class="nav-text">Manage Events</span>
                            }
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

        </nav>

        <AuthorizeView>
            <Authorized>
                <div class="logout-container px-3">
                    <button type="button" class="nav-link logout-link logout-button" @onclick="Logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span>
                        @if (!isCollapsed)
                        {
                            <span class="nav-text">Logout</span>
                        }
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private bool isCollapsed = false;

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("/account/logout", forceLoad: true);
    }
}